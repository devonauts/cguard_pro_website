---
import '../styles/global.css';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import type { Lang } from '../i18n/index';

export interface Props {
  title: string;
  lang?: Lang;
  description?: string;
  image?: string;
  canonicalURL?: string;
  noIndex?: boolean;
}

const {
  title,
  lang = 'es',
  description = 'CGuardPro — La plataforma inteligente de gestión de seguridad diseñada para empresas de seguridad modernas.',
  image = '/og-image.jpg',
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
  noIndex = false,
} = Astro.props;

const siteName = 'CGuardPro';
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
const pathname = Astro.url.pathname;
const esURL = new URL(pathname.replace(/^\/en/, '') || '/', Astro.site).href;
const enURL = new URL(`/en${pathname === '/' ? '' : pathname.replace(/^\/en/, '')}`, Astro.site).href;
---

<!doctype html>
<html lang={lang === 'es' ? 'es-EC' : lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Theme init (runs before paint → no flash). Follows the saved choice, else the
         OS preference. Toggled from the navbar. -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t !== 'light' && t !== 'dark') t = 'dark'; // matte-black SpaceX look is dark-first
          document.documentElement.classList.toggle('light', t === 'light');
        } catch (e) {}
      })();
    </script>

    <!-- Primary Meta -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Geo Targeting -->
    {lang === 'es' ? (
      <>
        <meta name="geo.region" content="EC" />
        <meta name="geo.placename" content="Quito, Ecuador" />
        <meta name="geo.position" content="-0.1807;-78.4678" />
        <meta name="ICBM" content="-0.1807, -78.4678" />
      </>
    ) : (
      <>
        <meta name="geo.region" content="US-TX" />
        <meta name="geo.placename" content="Austin, Texas" />
        <meta name="geo.position" content="30.2672;-97.7431" />
        <meta name="ICBM" content="30.2672, -97.7431" />
      </>
    )}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site).href} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content={lang === 'es' ? 'es_EC' : 'en_US'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site).href} />

    <!-- hreflang alternate links -->
    <link rel="alternate" hreflang="es" href={esURL} />
    <link rel="alternate" hreflang="en" href={enURL} />
    <link rel="alternate" hreflang="x-default" href={esURL} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0A0A0A" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#F6F7F9" media="(prefers-color-scheme: light)" />

    <!-- Structured Data: Organization (brand + logo for knowledge panel) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "CGuardPro",
      "url": "https://cguardpro.com",
      "logo": "https://cguardpro.com/logo.png",
      "description": lang === 'es'
        ? "Plataforma de operaciones de seguridad para empresas de seguridad privada: gestión de guardias, rondas GPS, turnos, despacho, incidentes, portal del cliente y nómina."
        : "Security operations platform for private security companies: guard management, GPS patrol tracking, scheduling, dispatch, incident reporting, client portal, and payroll.",
      "sameAs": [
        "https://www.instagram.com/cguardpro",
        "https://www.linkedin.com/company/cguardpro"
      ]
    })} />

    <!-- Structured Data: SoftwareApplication -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "CGuardPro",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "Web, iOS, Android",
        "description": description,
        "url": "https://cguardpro.com",
        "offers": {
          "@type": "Offer",
          "priceCurrency": "USD",
          "price": "5.00",
          "priceValidUntil": "2027-12-31"
        },
        "provider": {
          "@type": "Organization",
          "name": "CGuardPro",
          "url": "https://cguardpro.com"
        },
        "areaServed": lang === 'es' ? {
          "@type": "Country",
          "name": "Ecuador"
        } : [
          { "@type": "State", "name": "Texas" },
          { "@type": "Country", "name": "United States" }
        ]
      })} />

    <!-- Structured Data: LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify(lang === 'es' ? {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "CGuardPro",
        "description": "Plataforma de gestión de seguridad para empresas de seguridad privada en Ecuador",
        "url": "https://cguardpro.com",
        "telephone": "+593995914128",
        "email": "sales@cguardpro.com",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Quito",
          "addressRegion": "Pichincha",
          "addressCountry": "EC"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": -0.1807,
          "longitude": -78.4678
        },
        "areaServed": [
          { "@type": "City", "name": "Quito" },
          { "@type": "City", "name": "Guayaquil" },
          { "@type": "City", "name": "Cuenca" },
          { "@type": "Country", "name": "Ecuador" }
        ],
        "priceRange": "$$",
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
          "opens": "08:00",
          "closes": "18:00"
        }
      } : {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "CGuardPro",
        "description": "Security guard management software headquartered in Austin, Texas. Serving security companies across Texas and the United States.",
        "url": "https://cguardpro.com/en",
        "telephone": "+15127012880",
        "email": "sales@cguardpro.com",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "289 Centuryplant Rd",
          "addressLocality": "Leander",
          "addressRegion": "TX",
          "postalCode": "78641",
          "addressCountry": "US"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 30.5788,
          "longitude": -97.8531
        },
        "areaServed": [
          { "@type": "City", "name": "Leander" },
          { "@type": "City", "name": "Austin" },
          { "@type": "City", "name": "San Antonio" },
          { "@type": "City", "name": "Houston" },
          { "@type": "City", "name": "Dallas" },
          { "@type": "City", "name": "Round Rock" },
          { "@type": "State", "name": "Texas" }
        ],
        "priceRange": "$$",
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
          "opens": "08:00",
          "closes": "18:00"
        }
      })} />

    <!-- Preconnect for fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="min-h-screen">
    <slot />
    <WhatsAppButton lang={lang} />
    <script>
      // Intersection Observer for scroll animations
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.animate-on-scroll').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
