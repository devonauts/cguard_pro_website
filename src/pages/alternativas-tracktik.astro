---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
const lang = 'es';

const rows = [
  { c: 'Idioma de la plataforma y del soporte', cg: 'Español nativo (plataforma, apps y soporte)', tt: 'Inglés primero; sin sitio localizado para LATAM' },
  { c: 'Precios', cg: 'Públicos y por puesto — ver /pricing', tt: 'Bajo cotización; terceros reportan planes por usuario/mes más cargos de implementación*' },
  { c: 'Implementación', cg: 'Días: puestos, turnos y QR impresos, sin consultores', tt: 'Proyectos de implementación formales, pensados para grandes corporativos' },
  { c: 'Rondas', cg: 'QR/NFC con el celular del guardia, verificación GPS en servidor', tt: 'Guard tour con checkpoints' },
  { c: 'Radio PTT integrada', cg: 'Sí — canal de voz en la app, sin comprar radios', tt: 'No es su enfoque' },
  { c: 'Bitácora / parte de novedades', cg: 'Sí, con pase de turno automático al relevo', tt: 'Reportes configurables' },
  { c: 'Botón de pánico (guardia y cliente final)', cg: 'Sí, con protocolo completo en la central', tt: 'Funciones de seguridad del personal' },
  { c: 'Portal del cliente', cg: 'Incluido, con app para el cliente final', tt: 'Disponible en planes superiores' },
  { c: 'Terminología LATAM (sacafrancos, novedades, rondines)', cg: 'Nativa', tt: 'No aplica' },
];

const faqs = [
  { q: '¿CGuardPro es una alternativa real a TrackTik para una empresa en LATAM?', a: 'Sí, si tu operación es en español y quieres precios claros e implementación rápida. TrackTik es una plataforma sólida orientada a grandes corporativos de habla inglesa; CGuardPro cubre el mismo núcleo operativo (turnos, rondas, incidentes, supervisión GPS, portal del cliente) con vocabulario, soporte y precios pensados para América Latina.' },
  { q: '¿Qué me cuesta cambiarme?', a: 'La implementación típica toma días: se cargan puestos, guardias y turnos, se imprimen los códigos QR y el personal instala la app. No hay hardware propietario ni contratos de implementación.' },
  { q: '¿Dónde veo los precios de CGuardPro?', a: 'En la página de precios — son públicos, por puesto y sin sorpresas. No necesitas pasar por una llamada de ventas para saber cuánto cuesta.' },
  { q: '¿Qué no hace CGuardPro que TrackTik sí?', a: 'TrackTik tiene años de presencia enterprise en Norteamérica y integraciones orientadas a ese mercado. Si tu operación exige esas integraciones específicas y opera en inglés, evalúalo; si tu operación vive en español, CGuardPro te da el núcleo completo sin esa complejidad.' },
];
---

<Layout
  hasAlternate={false}
  title="Alternativa a TrackTik en Español — CGuardPro"
  lang={lang}
  description="¿Buscas una alternativa a TrackTik en español? Compara: precios públicos por puesto, implementación en días, rondas QR, radio PTT, bitácora digital y portal del cliente — hecho para empresas de seguridad de América Latina."
>
  <Navbar lang={lang} />

  <Fragment set:html={`<script type="application/ld+json">${JSON.stringify({
    '@context': 'https://schema.org', '@type': 'FAQPage',
    mainEntity: faqs.map(({ q, a }) => ({ '@type': 'Question', name: q, acceptedAnswer: { '@type': 'Answer', text: a } })),
  })}</script>`} />

  <main class="pt-28 lg:pt-32 pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <span class="section-label mb-5 inline-flex">Comparativa</span>
      <h1 class="font-display font-bold text-[2.3rem] lg:text-[3rem] leading-[1.08] tracking-tight">
        Alternativa a TrackTik<br /><span class="gold-gradient-text">en español y sin cotizaciones a ciegas</span>
      </h1>
      <p class="mt-6 text-lg leading-relaxed max-w-2xl" style="color:var(--text-muted)">
        TrackTik es una plataforma respetada, construida para grandes operaciones de habla
        inglesa en Norteamérica. Si tu empresa de seguridad opera en América Latina, hay
        tres diferencias que pesan más que cualquier lista de funciones: el idioma, el
        precio y el tiempo de implementación.
      </p>

      <div class="mt-12 overflow-x-auto rounded-2xl" style="border:1px solid var(--border)">
        <table class="w-full text-sm" style="background:var(--surface)">
          <thead>
            <tr style="border-bottom:1px solid var(--border)">
              <th class="text-left p-4 font-semibold" style="color:var(--text-faint)"></th>
              <th class="text-left p-4 font-semibold" style="color:var(--brand)">CGuardPro</th>
              <th class="text-left p-4 font-semibold">TrackTik</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((r) => (
              <tr style="border-bottom:1px solid var(--border)">
                <td class="p-4 font-medium">{r.c}</td>
                <td class="p-4" style="color:var(--text-muted)">{r.cg}</td>
                <td class="p-4" style="color:var(--text-muted)">{r.tt}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-3 text-xs" style="color:var(--text-faint)">
        *Información sobre TrackTik basada en su sitio público y en datos de terceros
        (Capterra, TrustRadius, ITQlick) a la fecha de publicación; verifica con el
        proveedor. TrackTik es una marca de su respectivo propietario.
      </p>

      <div class="mt-14 space-y-4">
        <h2 class="font-display font-bold text-2xl mb-6">Preguntas frecuentes</h2>
        {faqs.map(({ q, a }) => (
          <details class="card-glass rounded-xl px-5 py-4 group">
            <summary class="cursor-pointer font-semibold text-[15px] list-none flex items-center justify-between gap-4">
              {q}<span class="shrink-0 transition-transform group-open:rotate-45" style="color:var(--brand)">+</span>
            </summary>
            <p class="mt-3 text-sm leading-relaxed" style="color:var(--text-muted)">{a}</p>
          </details>
        ))}
      </div>

      <div class="mt-14 flex flex-wrap gap-2.5">
        {[
          { label: 'Ver precios públicos', href: '/pricing' },
          { label: 'Control de rondas QR', href: '/control-de-rondas-qr' },
          { label: 'Radio PTT', href: '/radio-ptt-para-guardias' },
          { label: 'Software en Ecuador', href: '/ecuador' },
          { label: '¿Cuánto cuesta un software de seguridad?', href: '/cuanto-cuesta-software-seguridad' },
        ].map((r) => (
          <a href={r.href} class="rounded-full border px-4 py-2 text-sm transition-colors hover:border-brand" style="color:var(--text-muted);border-color:var(--border)">{r.label}</a>
        ))}
      </div>

      <div class="mt-14 rounded-3xl px-8 py-12 text-center relative overflow-hidden" style="background:#141414">
        <div class="gold-line absolute top-0 left-0 right-0"></div>
        <h2 class="font-display font-bold text-2xl text-white">Compara con tu operación real</h2>
        <p class="mt-3 text-white/60 max-w-xl mx-auto">Agenda una demo en español y evalúa CGuardPro con tus puestos, tus turnos y tus rondas.</p>
        <div class="mt-6"><a href="/contact" class="btn-primary">Agendar una demo</a></div>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>
