---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { useTranslations, localePath } from '../i18n/index';

const lang = 'es';
const t = useTranslations(lang);
const p = (path: string) => localePath(lang, path);
---

<Layout
  title="Nosotros — El equipo detrás de CGuardPro"
  lang={lang}
  description="Conoce a CGuardPro: la plataforma de operaciones para empresas de seguridad privada creada por gente que conoce la industria. Nuestra historia y misión."
>
  <Navbar lang={lang} />

  <main class="pt-32 pb-24">
    <div class="max-w-7xl mx-auto px-6">

      <!-- Hero -->
      <div class="max-w-3xl mb-20">
        <span class="section-label mb-6 inline-flex animate-on-scroll">{t.about.badge}</span>
        <h1 class="font-display font-bold text-5xl lg:text-6xl mb-6 leading-tight animate-on-scroll">
          {t.about.headline1}<br />
          <span class="text-brand">{t.about.headline2}</span>
        </h1>
        <p class="text-white/60 text-xl leading-relaxed animate-on-scroll">
          {t.about.subheadline}
        </p>
      </div>

      <!-- Story -->
      <div class="grid lg:grid-cols-2 gap-16 items-start mb-24">
        <div class="animate-on-scroll">
          <h2 class="font-display font-bold text-3xl mb-4">{t.about.storyTitle}</h2>
          <div class="space-y-4 text-white/60 leading-relaxed">
            {t.about.story.map(para => <p>{para}</p>)}
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4 animate-on-scroll">
          {[
            { n: '500+', l: t.about.statsLabels[0] },
            { n: '12K+', l: t.about.statsLabels[1] },
            { n: '18+',  l: t.about.statsLabels[2] },
            { n: '4.8★', l: t.about.statsLabels[3] },
          ].map(({ n, l }) => (
            <div class="card-glass p-6 text-center">
              <div class="font-display font-bold text-3xl text-brand mb-1">{n}</div>
              <div class="text-white/50 text-sm">{l}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Values -->
      <div class="mb-24">
        <h2 class="font-display font-bold text-3xl mb-10 animate-on-scroll">{t.about.valuesTitle}</h2>
        <div class="grid md:grid-cols-2 gap-6">
          {t.about.values.map(({ title, desc }, i) => (
            <div class="card-glass p-6 animate-on-scroll" style={`transition-delay:${i * 80}ms`}>
              <div class="flex items-center gap-3 mb-3">
                <div class="w-2 h-2 rounded-full bg-brand"></div>
                <h3 class="font-display font-semibold text-lg">{title}</h3>
              </div>
              <p class="text-white/50 text-sm leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center card-glass rounded-3xl p-12 animate-on-scroll relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-brand/10 to-transparent pointer-events-none" aria-hidden="true"></div>
        <div class="relative">
          <h2 class="font-display font-bold text-4xl mb-4">{t.about.ctaTitle}</h2>
          <p class="text-white/60 mb-8 max-w-lg mx-auto">{t.about.ctaSubtitle}</p>
          <a href={p('/contact')} class="btn-primary text-base px-8 py-3.5">{t.about.ctaBtn}</a>
        </div>
      </div>

    </div>
  </main>

  <Footer lang={lang} />
</Layout>

