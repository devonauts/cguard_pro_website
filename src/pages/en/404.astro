---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations, localePath } from '../../i18n/index';

const lang = 'en';
const t = useTranslations(lang);
const p = (path: string) => localePath(lang, path);
---

<Layout title="404" lang={lang} noIndex={true}>
  <Navbar lang={lang} />
  <main class="min-h-screen flex items-center justify-center px-6 pt-20">
    <div class="text-center">
      <div class="font-mono text-brand text-sm mb-4 tracking-widest">{t.notFound.code}</div>
      <h1 class="font-display font-bold text-8xl text-white/10 mb-4">404</h1>
      <h2 class="font-display font-bold text-3xl mb-4">{t.notFound.title}</h2>
      <p class="text-white/50 mb-8 max-w-sm mx-auto">{t.notFound.desc}</p>
      <a href={p('/')} class="btn-primary">{t.notFound.back}</a>
    </div>
  </main>
  <Footer lang={lang} />
</Layout>
