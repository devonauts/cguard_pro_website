---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';

const lang = 'en';
const posts = (await getCollection('blog'))
  .filter(post => post.data.lang === 'en')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title="Blog — Security Guard Management Software Insights"
  lang={lang}
  description="Articles, guides, and resources about security guard management, technology for security companies, and best practices for the private security industry."
>
  <Navbar lang={lang} />

  <main class="pt-32 pb-24">
    <div class="max-w-7xl mx-auto px-6">

      <!-- Header -->
      <div class="text-center mb-16">
        <span class="section-label mb-4 inline-flex">Blog</span>
        <h1 class="font-display font-bold text-5xl mb-4 animate-on-scroll">
          Security Industry<br />
          <span class="text-brand">Insights & Guides</span>
        </h1>
        <p class="text-white/50 text-lg max-w-xl mx-auto animate-on-scroll">
          Expert articles on guard management, technology, compliance, and growing your security business.
        </p>
      </div>

      <!-- Posts Grid -->
      {posts.length > 0 ? (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <a href={`/en/blog/${post.id}`} class="card-glass p-6 rounded-2xl hover:border-brand/30 transition-all duration-300 group animate-on-scroll">
              <div class="mb-4">
                <time class="text-xs text-white/30 font-mono">
                  {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </div>
              <h2 class="font-display font-semibold text-lg text-white mb-2 group-hover:text-brand transition-colors line-clamp-2">
                {post.data.title}
              </h2>
              <p class="text-white/50 text-sm leading-relaxed line-clamp-3">
                {post.data.description}
              </p>
              <div class="mt-4 flex flex-wrap gap-2">
                {post.data.tags?.slice(0, 3).map((tag: string) => (
                  <span class="text-xs bg-brand/10 text-brand/80 px-2 py-0.5 rounded-full">{tag}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-center text-white/50">No posts yet. Check back soon!</p>
      )}

    </div>
  </main>

  <Footer lang={lang} />
</Layout>
