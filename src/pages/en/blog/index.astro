---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';

const lang = 'en';
const posts = (await getCollection('blog'))
  .filter(post => post.data.lang === 'en')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

/** Curated categories over free-form tags (same pattern as the ES index). */
const CATEGORIES: { id: string; label: string; tags: string[] }[] = [
  { id: 'texas', label: 'Texas & Compliance', tags: ['texas', 'TDLR', 'licensing', 'compliance', 'insurance'] },
  { id: 'patrols', label: 'Patrols', tags: ['patrols', 'guard tour'] },
  { id: 'scheduling', label: 'Scheduling & Attendance', tags: ['scheduling', 'attendance', 'payroll'] },
  { id: 'reports', label: 'Reports & Incidents', tags: ['incident reporting', 'reports', 'post orders', 'billing'] },
  { id: 'safety', label: 'Safety & Communication', tags: ['safety', 'radio', 'protocols', 'supervision'] },
  { id: 'clients', label: 'Clients & Sales', tags: ['clients', 'sales', 'contracts', 'marketing'] },
  { id: 'operations', label: 'Operations & Growth', tags: ['operations', 'workforce', 'turnover', 'kpis', 'dispatch', 'technology', 'startup'] },
];

function categoryOf(tags: string[]): { id: string; label: string } {
  const lower = tags.map((t) => t.toLowerCase());
  for (const c of CATEGORIES) {
    if (c.tags.some((t) => lower.includes(t.toLowerCase()))) return c;
  }
  return { id: 'operations', label: 'Operations & Growth' };
}

const withCat = posts.map((p) => ({ post: p, cat: categoryOf(p.data.tags) }));
const counts = new Map<string, number>();
for (const { cat } of withCat) counts.set(cat.id, (counts.get(cat.id) || 0) + 1);
const chips = CATEGORIES.filter((c) => counts.get(c.id));

const featured = withCat[0];
const rest = withCat.slice(1);

const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Layout
  title="Blog — Security Guard Management Software Insights"
  lang={lang}
  description="Practical guides for security guard companies: patrols, scheduling, incident reporting, panic response, client retention, and Texas compliance."
>
  <Navbar lang={lang} />

  <main class="pt-32 pb-24">
    <div class="max-w-7xl mx-auto px-6">

      <!-- Header -->
      <div class="text-center mb-12">
        <span class="section-label mb-4 inline-flex">Blog</span>
        <h1 class="font-display font-bold text-5xl mb-4 animate-on-scroll">
          Security Industry<br />
          <span class="text-brand">Insights & Guides</span>
        </h1>
        <p class="text-white/50 text-lg max-w-xl mx-auto animate-on-scroll">
          {posts.length} practical guides on patrols, scheduling, incident reporting, compliance, and growing your security business.
        </p>
      </div>

      <!-- Featured (latest) -->
      {featured && (
        <a href={`/en/blog/${featured.post.id}`} class="card-glass group hover:border-brand/30 transition-all duration-300 grid md:grid-cols-2 overflow-hidden mb-12 animate-on-scroll">
          {featured.post.data.image && (
            <img src={featured.post.data.image} alt="" width="1200" height="630" class="w-full h-full object-cover" loading="eager" decoding="async" />
          )}
          <div class="p-8 flex flex-col justify-center">
            <div class="flex items-center gap-2.5 mb-4">
              <span class="text-[11px] font-mono font-bold tracking-wider uppercase px-2.5 py-1 rounded-full" style="background:rgba(200,134,10,0.15);color:var(--brand)">Featured</span>
              <span class="text-xs bg-brand/10 text-brand px-2 py-0.5 rounded-full">{featured.cat.label}</span>
              <time class="text-xs text-white/40 font-mono">{fmt(featured.post.data.pubDate)}</time>
            </div>
            <h2 class="font-display font-bold text-2xl lg:text-[1.7rem] leading-snug text-white group-hover:text-brand transition-colors mb-3">
              {featured.post.data.title}
            </h2>
            <p class="text-white/50 text-[15px] leading-relaxed line-clamp-3">{featured.post.data.description}</p>
            <span class="mt-5 text-brand text-sm font-semibold flex items-center gap-1">
              Read article
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      )}

      <!-- Filters: search + category chips -->
      <div class="mb-10 space-y-4">
        <div class="max-w-md mx-auto relative">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="absolute left-4 top-1/2 -translate-y-1/2 text-white/30" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input
            id="blog-search"
            type="search"
            placeholder="Search articles…"
            class="w-full rounded-full border border-white/10 bg-white/5 py-3 pl-11 pr-5 text-sm text-white placeholder-white/30 outline-none focus:border-brand/50 transition-colors"
            autocomplete="off"
          />
        </div>
        <div class="flex flex-wrap justify-center gap-2" role="group" aria-label="Categories">
          <button type="button" data-cat="all" class="blog-chip is-active" aria-pressed="true">All <span class="cnt">{posts.length}</span></button>
          {chips.map((c) => (
            <button type="button" data-cat={c.id} class="blog-chip" aria-pressed="false">{c.label} <span class="cnt">{counts.get(c.id)}</span></button>
          ))}
        </div>
      </div>

      <!-- Blog Grid -->
      <div id="blog-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {rest.map(({ post, cat }) => (
          <a
            href={`/en/blog/${post.id}`}
            class="blog-card card-glass group hover:border-brand/30 transition-all duration-300"
            data-cat={cat.id}
            data-search={`${post.data.title} ${post.data.description}`.toLowerCase()}
          >
            {post.data.image && (
              <img src={post.data.image} alt="" width="1200" height="630" class="w-full rounded-t-[inherit]" loading="lazy" decoding="async" />
            )}
            <div class="p-6">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xs bg-brand/10 text-brand px-2 py-0.5 rounded-full">{cat.label}</span>
                <time class="text-xs text-white/40 font-mono">{fmt(post.data.pubDate)}</time>
              </div>
              <h2 class="font-display font-semibold text-lg text-white group-hover:text-brand transition-colors mb-2 line-clamp-2">
                {post.data.title}
              </h2>
              <p class="text-white/50 text-sm line-clamp-3">{post.data.description}</p>
              <div class="mt-4 text-brand text-sm font-medium flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                Read more
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>

      <p id="blog-empty" class="hidden text-center text-white/40 py-16">
        No articles match your search.
      </p>

    </div>
  </main>

  <Footer lang={lang} />
</Layout>

<style>
  .blog-chip {
    font-family: var(--font-family-mono, ui-monospace);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 8px 16px;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.55);
    background: transparent;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .blog-chip:hover { color: #fff; border-color: rgba(255, 255, 255, 0.3); }
  .blog-chip.is-active {
    color: var(--brand, #C8860A);
    border-color: color-mix(in srgb, var(--brand, #C8860A) 55%, transparent);
    background: color-mix(in srgb, var(--brand, #C8860A) 10%, transparent);
  }
  .blog-chip .cnt { opacity: 0.55; margin-left: 2px; }
</style>

<script>
  const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('.blog-chip'));
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.blog-card'));
  const search = document.getElementById('blog-search') as HTMLInputElement | null;
  const empty = document.getElementById('blog-empty');

  let activeCat = 'all';

  function apply() {
    const q = (search?.value || '').trim().toLowerCase();
    let visible = 0;
    for (const card of cards) {
      const okCat = activeCat === 'all' || card.dataset.cat === activeCat;
      const okSearch = !q || (card.dataset.search || '').includes(q);
      const show = okCat && okSearch;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    }
    empty?.classList.toggle('hidden', visible > 0);
  }

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      activeCat = chip.dataset.cat || 'all';
      chips.forEach((c) => {
        const on = c === chip;
        c.classList.toggle('is-active', on);
        c.setAttribute('aria-pressed', String(on));
      });
      apply();
    });
  });
  search?.addEventListener('input', apply);
</script>
