---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations, localePath } from '../../i18n/index';

const lang = 'en';
const t = useTranslations(lang);
const p = (path: string) => localePath(lang, path);

const featureIcons = [
  `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  `<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>`,
  `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>`,
  `<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>`,
  `<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>`,
  `<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>`,
];
---

<Layout
  title="CGuardPro — Security Guard Management Software | Austin, TX"
  lang={lang}
  description={t.siteDescription}
>
  <Navbar lang={lang} />

  <!-- ─── Hero (producto primero) ─────────────────────────────────── -->
  <section class="relative overflow-hidden pt-28 lg:pt-36 pb-20 lg:pb-28">
    <div class="absolute inset-0 grid-bg opacity-100 pointer-events-none" aria-hidden="true"></div>
    <div class="absolute -top-24 right-[-10%] w-[720px] h-[520px] bg-brand/10 rounded-full blur-[130px] pointer-events-none" aria-hidden="true"></div>

    <div class="relative max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-[1.02fr_1.1fr] gap-14 lg:gap-8 items-center">

        <!-- LEFT: copy -->
        <div class="text-center lg:text-left max-w-xl mx-auto lg:mx-0">
          <span class="section-label animate-fade-in">
            <span class="w-1.5 h-1.5 rounded-full bg-brand animate-pulse inline-block"></span>
            {t.hero.badge}
          </span>
          <h1 class="font-display font-bold text-[2.6rem] sm:text-5xl lg:text-[3.4rem] tracking-tight leading-[1.07] mt-6 mb-5 animate-fade-up" style="animation-delay:.1s">
            {t.hero.headline1}{' '}
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand to-brand-light glow-text">{t.hero.headline2}</span>
          </h1>
          <p class="text-white/60 text-lg leading-relaxed mb-8 animate-fade-up" style="animation-delay:.2s">
            {t.hero.subheadline}
          </p>
          <div class="flex flex-col sm:flex-row items-center lg:items-start gap-3 animate-fade-up" style="animation-delay:.3s">
            <a href={p('/contact')} class="btn-primary text-base px-7 py-3.5 w-full sm:w-auto justify-center">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              {t.hero.ctaPrimary}
            </a>
            <a href={p('/#how-it-works')} class="btn-outline text-base px-7 py-3.5 w-full sm:w-auto justify-center">
              {t.hero.ctaSecondary}
            </a>
          </div>
          <div class="mt-8 flex flex-wrap items-center justify-center lg:justify-start gap-x-5 gap-y-2 animate-fade-up" style="animation-delay:.4s">
            {[t.hero.trust1, t.hero.trust2, t.hero.trust3].map((x) => (
              <span class="inline-flex items-center gap-1.5 text-white/50 text-sm">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-brand shrink-0"><path d="M20 6 9 17l-5-5"/></svg>
                {x}
              </span>
            ))}
          </div>
        </div>

        <!-- RIGHT: product mockup -->
        <div class="relative animate-fade-up lg:pl-4" style="animation-delay:.35s">
          <div class="card-glass p-1.5 rounded-2xl shadow-2xl shadow-black/50">
            <div class="bg-navy-lighter rounded-xl overflow-hidden">
              <div class="flex items-center gap-2 px-3.5 py-2.5 border-b border-white/5">
                <div class="flex gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full bg-white/10"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-white/10"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-white/10"></span>
                </div>
                <div class="flex-1 bg-navy/60 rounded-md px-3 py-1 text-[11px] text-white/30 font-mono mx-2 truncate">{t.hero.dashboardUrl}</div>
              </div>
              <div class="grid grid-cols-[1.55fr_1fr] gap-2.5 p-2.5">
                <div class="relative rounded-lg overflow-hidden border border-white/5 min-h-[210px]">
                  <svg viewBox="0 0 340 240" preserveAspectRatio="xMidYMid slice" class="absolute inset-0 w-full h-full">
                    <rect width="340" height="240" fill="#0b141e"></rect>
                    <g stroke="rgba(255,255,255,0.05)" stroke-width="7" fill="none" stroke-linecap="round">
                      <path d="M-10 70 H 350"></path><path d="M-10 168 H 350"></path>
                      <path d="M96 -10 V 250"></path><path d="M244 -10 V 250"></path>
                    </g>
                    <g stroke="rgba(255,255,255,0.035)" stroke-width="2.5" fill="none">
                      <path d="M-10 118 H 350"></path><path d="M170 -10 V 250"></path><path d="M40 -10 L 120 250"></path>
                    </g>
                    <path d="M64 190 L118 128 L206 150 L280 66" fill="none" stroke="#E9A832" stroke-width="2.5" stroke-dasharray="1 6" stroke-linecap="round" opacity="0.9"></path>
                    {[[64,190,'1'],[118,128,'2'],[206,150,'3'],[280,66,'4']].map(([x,y,n]) => (
                      <g>
                        <circle cx={x} cy={y} r="10" fill="#C8860A"></circle>
                        <circle cx={x} cy={y} r="10" fill="none" stroke="#fff" stroke-width="1.5" opacity="0.85"></circle>
                        <text x={x} y={Number(y)+3.5} text-anchor="middle" font-size="10" font-weight="700" fill="#0b141e" font-family="sans-serif">{n}</text>
                      </g>
                    ))}
                    <circle cx="150" cy="200" r="14" fill="#2ecc71" opacity="0.18"></circle>
                    <circle cx="150" cy="200" r="5" fill="#2ecc71"></circle>
                  </svg>
                  <div class="absolute top-2 left-2.5 flex items-center gap-1.5 text-[10px] font-medium text-white/70 bg-navy/70 backdrop-blur px-2 py-1 rounded-full">
                    <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background:#2ecc71"></span>{t.hero.mockMap}
                  </div>
                </div>
                <div class="flex flex-col gap-2.5">
                  <div class="grid grid-cols-2 gap-2">
                    <div class="bg-navy/60 rounded-lg p-2.5 border border-white/5">
                      <div class="text-[10px] text-white/40">{t.hero.mockStats[0]}</div>
                      <div class="text-xl font-bold text-white leading-tight">{t.hero.mockValues[0]}</div>
                    </div>
                    <div class="bg-navy/60 rounded-lg p-2.5 border border-white/5">
                      <div class="text-[10px] text-white/40">{t.hero.mockStats[1]}</div>
                      <div class="text-xl font-bold text-white leading-tight">{t.hero.mockValues[1]}</div>
                    </div>
                  </div>
                  <div class="bg-navy/60 rounded-lg p-2.5 border border-white/5 flex-1">
                    <div class="text-[10px] text-white/40 mb-2">{t.hero.mockOnDuty}</div>
                    {[t.hero.mockGuard1, t.hero.mockGuard2, t.hero.mockGuard3].map((g) => (
                      <div class="flex items-center gap-2 py-1">
                        <span class="w-1.5 h-1.5 rounded-full shrink-0" style="background:#2ecc71"></span>
                        <span class="text-[11px] text-white/60 truncate">{g}</span>
                      </div>
                    ))}
                    <div class="flex items-center gap-2 py-1 mt-1 border-t border-white/5 pt-2">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#C8860A" stroke-width="2"><path d="M3 12h4l3-9 4 18 3-9h4"/></svg>
                      <span class="text-[11px] text-brand truncate">{t.hero.mockRoute}</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="hidden sm:block absolute -bottom-10 -left-6 lg:-left-10 w-36 rounded-[1.4rem] border-[6px] border-navy-900 bg-navy-lighter shadow-2xl shadow-black/60 overflow-hidden -rotate-[4deg]">
            <div class="bg-navy px-3 pt-3 pb-3">
              <div class="text-[9px] text-white/40">{t.hero.phoneTitle}</div>
              <div class="text-xs font-bold text-white">CGuardPro</div>
              <div class="mt-2 rounded-lg px-2 py-1.5" style="background:rgba(46,204,113,.12);border:1px solid rgba(46,204,113,.35)">
                <div class="text-[8px]" style="color:#2ecc71">● {t.hero.phoneStatus}</div>
              </div>
              <div class="mt-2 h-14 rounded-lg overflow-hidden">
                <svg viewBox="0 0 120 70" class="w-full h-full"><rect width="120" height="70" fill="#0b141e"></rect><g stroke="rgba(255,255,255,.06)" stroke-width="3"><path d="M0 30 H120"></path><path d="M50 0 V70"></path></g><path d="M15 55 L45 30 L90 20" fill="none" stroke="#E9A832" stroke-width="2" stroke-dasharray="1 4"></path><circle cx="90" cy="20" r="5" fill="#C8860A"></circle></svg>
              </div>
              <div class="mt-2 rounded-lg bg-brand text-center text-[8px] font-bold py-1.5" style="color:#0b141e">{t.hero.phoneCta}</div>
            </div>
          </div>

          <div class="absolute inset-x-12 -bottom-8 h-16 bg-brand/15 blur-2xl rounded-full pointer-events-none" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Stats band ────────────────────────────────────────────────── -->
  <section class="py-14 lg:py-16 border-y" style="background:var(--surface-2);border-color:var(--border)">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-10 text-center">
        {t.stats.map(({ value, label, sub }) => (
          <div class="animate-on-scroll">
            <div class="font-display font-bold text-4xl lg:text-[2.75rem] leading-none mb-2" style="color:var(--brand)">{value}</div>
            <div class="font-semibold text-sm" style="color:var(--text)">{label}</div>
            <div class="text-xs mt-1" style="color:var(--text-faint)">{sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Features ─────────────────────────────────────────────────── -->
  <section id="features" class="py-20 lg:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-2xl mb-12 lg:mb-16">
        <div class="text-xs font-semibold tracking-[0.15em] uppercase mb-3 animate-on-scroll" style="color:var(--brand)">{t.features.badge}</div>
        <h2 class="font-display font-bold text-[2rem] lg:text-[2.75rem] leading-[1.1] tracking-tight mb-4 animate-on-scroll" style="color:var(--text)">
          {t.features.headline1} <span style="color:var(--brand)">{t.features.headline2}</span>
        </h2>
        <p class="text-lg leading-relaxed animate-on-scroll" style="color:var(--text-muted)">{t.features.subheadline}</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {t.features.items.map(({ title, desc }, i) => (
          <article class="rounded-2xl p-6 lg:p-7 transition-all duration-300 hover:-translate-y-1 animate-on-scroll"
                   style={`background:var(--surface);border:1px solid var(--border);box-shadow:var(--card-shadow);transition-delay:${i * 60}ms`}>
            <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5" style="background:rgba(200,134,10,0.10)">
              <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="#C8860A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <Fragment set:html={featureIcons[i]} />
              </svg>
            </div>
            <h3 class="font-display font-semibold text-lg mb-2" style="color:var(--text)">{title}</h3>
            <p class="text-sm leading-relaxed" style="color:var(--text-muted)">{desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── How it works ─────────────────────────────────────────────── -->
  <section id="how-it-works" class="py-20 lg:py-28" style="background:var(--surface-2)">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-2xl mb-12 lg:mb-16">
        <div class="text-xs font-semibold tracking-[0.15em] uppercase mb-3 animate-on-scroll" style="color:var(--brand)">{t.howItWorks.badge}</div>
        <h2 class="font-display font-bold text-[2rem] lg:text-[2.75rem] leading-[1.1] tracking-tight animate-on-scroll" style="color:var(--text)">
          {t.howItWorks.headline1} <span style="color:var(--brand)">{t.howItWorks.headline2}</span>
        </h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-6">
        {t.howItWorks.steps.map(({ step, title, desc }, i) => (
          <div class="animate-on-scroll" style={`transition-delay:${i * 80}ms`}>
            <div class="w-11 h-11 rounded-xl flex items-center justify-center font-display font-bold text-base mb-4"
                 style="background:var(--surface);border:1px solid var(--border);color:var(--brand);box-shadow:var(--card-shadow)">{step}</div>
            <h3 class="font-display font-semibold text-lg mb-2" style="color:var(--text)">{title}</h3>
            <p class="text-sm leading-relaxed" style="color:var(--text-muted)">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Mobile app ───────────────────────────────────────────────── -->
  <section class="py-20 lg:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-14 lg:gap-10 items-center">
        <div class="animate-on-scroll">
          <div class="text-xs font-semibold tracking-[0.15em] uppercase mb-3" style="color:var(--brand)">{t.mobile.badge}</div>
          <h2 class="font-display font-bold text-[2rem] lg:text-[2.6rem] leading-[1.1] tracking-tight mb-5" style="color:var(--text)">
            {t.mobile.headline1} <span style="color:var(--brand)">{t.mobile.headline2}</span>
          </h2>
          <ul class="space-y-3.5 mb-8">
            {t.mobile.features.map((item) => (
              <li class="flex items-start gap-3 text-[15px]" style="color:var(--text-muted)">
                <span class="mt-0.5 shrink-0 w-5 h-5 rounded-full flex items-center justify-center" style="background:rgba(200,134,10,0.12)">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#C8860A" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href={p('/contact')} class="btn-primary">{t.mobile.ctaDemo}</a>
            <a href={p('/mobile-app')} class="btn-outline">{t.mobile.ctaLearn}</a>
          </div>
        </div>
        <div class="flex justify-center animate-on-scroll">
          <div class="w-60 rounded-[2.4rem] p-2 shadow-2xl" style="background:#0F1923;border:1px solid var(--border-strong)">
            <div class="rounded-[1.9rem] overflow-hidden" style="background:#0b141e">
              <div class="px-4 pt-4 pb-5">
                <div class="w-14 h-1 rounded-full mx-auto mb-5" style="background:rgba(255,255,255,0.14)"></div>
                <div class="rounded-2xl p-3.5 mb-3" style="background:rgba(46,204,113,0.12);border:1px solid rgba(46,204,113,0.3)">
                  <div class="text-[11px] font-mono mb-1" style="color:#2ecc71">● {t.mobile.phoneOnDuty}</div>
                  <div class="font-semibold text-white text-[15px]">{t.mobile.phoneSite}</div>
                  <div class="text-white/40 text-xs mt-0.5">{t.mobile.phoneShift}</div>
                </div>
                {t.mobile.phoneCheckpoints.map((c, i) => (
                  <div class="flex items-center gap-2.5 py-2 border-b" style="border-color:rgba(255,255,255,0.06)">
                    <span class={`w-2 h-2 rounded-full shrink-0`} style={i < 2 ? 'background:#C8860A' : 'background:rgba(255,255,255,0.2)'}></span>
                    <span class="text-[13px] text-white/70">{c}</span>
                  </div>
                ))}
                <button class="w-full mt-4 py-3 rounded-xl text-[13px] font-bold" style="background:#C8860A;color:#0b141e">{t.mobile.phoneReportBtn}</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Testimonials ─────────────────────────────────────────────── -->
  <section class="py-20 lg:py-28" style="background:var(--surface-2)">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-2xl mb-12 lg:mb-16">
        <div class="text-xs font-semibold tracking-[0.15em] uppercase mb-3 animate-on-scroll" style="color:var(--brand)">{t.testimonials.badge}</div>
        <h2 class="font-display font-bold text-[2rem] lg:text-[2.6rem] leading-[1.1] tracking-tight animate-on-scroll" style="color:var(--text)">{t.testimonials.headline}</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-5">
        {t.testimonials.items.map(({ quote, name, role, company }, i) => (
          <blockquote class="rounded-2xl p-7 animate-on-scroll" style={`background:var(--surface);border:1px solid var(--border);box-shadow:var(--card-shadow);transition-delay:${i * 80}ms`}>
            <div class="flex gap-0.5 mb-4">
              {[0,1,2,3,4].map(() => (<svg width="15" height="15" viewBox="0 0 24 24" fill="#C8860A" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/></svg>))}
            </div>
            <p class="text-[15px] leading-relaxed mb-6" style="color:var(--text)">“{quote}”</p>
            <footer class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold" style="background:rgba(200,134,10,0.14);color:var(--brand)">{name.charAt(0)}</div>
              <div>
                <div class="text-sm font-semibold" style="color:var(--text)">{name}</div>
                <div class="text-xs" style="color:var(--text-faint)">{role}, {company}</div>
              </div>
            </footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Final CTA (dark band) ────────────────────────────────────── -->
  <section class="py-20 lg:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <div class="relative rounded-3xl px-8 py-16 lg:py-20 text-center overflow-hidden animate-on-scroll" style="background:#0F1923">
        <div class="absolute -top-24 left-1/2 -translate-x-1/2 w-[600px] h-[300px] rounded-full blur-[120px] pointer-events-none" style="background:rgba(200,134,10,0.18)" aria-hidden="true"></div>
        <div class="relative">
          <h2 class="font-display font-bold text-3xl lg:text-[2.75rem] leading-tight tracking-tight mb-4 text-white">{t.cta.headline}</h2>
          <p class="text-lg max-w-xl mx-auto mb-9 text-white/60">{t.cta.subheadline}</p>
          <div class="flex flex-col sm:flex-row justify-center gap-3">
            <a href={p('/contact')} class="btn-primary text-base px-8 py-3.5 justify-center">{t.cta.primary}</a>
            <a href={p('/pricing')} class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-lg font-semibold text-base border border-white/20 text-white hover:bg-white/10 transition-colors">{t.cta.secondary}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer lang={lang} />
</Layout>
