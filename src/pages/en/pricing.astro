---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations, localePath } from '../../i18n/index';

const lang = 'en';
const t = useTranslations(lang);
const p = (path: string) => localePath(lang, path);
---

<Layout
  title={t.pricing.badge}
  lang={lang}
  description={t.siteDescription}
>
  <Navbar lang={lang} />

  <main class="pt-32 pb-24">
    <div class="max-w-7xl mx-auto px-6">

      <!-- Header -->
      <div class="text-center mb-16">
        <span class="section-label mb-4 inline-flex">{t.pricing.badge}</span>
        <h1 class="font-display font-bold text-5xl mb-4 animate-on-scroll">
          {t.pricing.headline1}<br />
          <span class="text-brand">{t.pricing.headline2}</span>
        </h1>
        <p class="text-white/50 text-lg max-w-xl mx-auto animate-on-scroll">
          {t.pricing.subheadline}
        </p>
      </div>

      <!-- Plans -->
      <div class="grid md:grid-cols-2 gap-6 mb-20 max-w-4xl mx-auto">
        {t.pricing.plans.map(({ name, price, period, desc, features, cta, highlight }, i) => (
          <div
            class={`relative card-glass p-8 animate-on-scroll flex flex-col
              ${highlight ? 'border-brand/50 shadow-[0_0_40px_rgba(200,134,10,0.12)]' : ''}`}
            style={`transition-delay:${i * 100}ms`}
          >
            {highlight && (
              <div class="absolute -top-px left-1/2 -translate-x-1/2 px-4 py-1 bg-brand text-white
                          text-xs font-mono font-medium rounded-b-lg tracking-widest uppercase">
                {t.pricing.mostPopular}
              </div>
            )}
            <div class="mb-6">
              <div class="font-display font-semibold text-white/70 text-sm mb-2">{name}</div>
              <div class="flex items-end gap-1 mb-2">
                {price === 'Custom' || price === 'Personalizado' ? (
                  <span class="font-display font-bold text-4xl text-white">{price}</span>
                ) : (
                  <>
                    <span class="font-mono text-lg text-white/50 mt-2">$</span>
                    <span class="font-display font-bold text-5xl text-white">{price}</span>
                    <span class="text-white/40 text-sm mb-2">{period}</span>
                  </>
                )}
              </div>
              <p class="text-white/50 text-sm">{desc}</p>
            </div>

            <ul class="space-y-3 mb-8 flex-1">
              {features.map(feat => (
                <li class="flex items-start gap-3 text-sm text-white/70">
                  <svg class={`mt-0.5 shrink-0 ${highlight ? 'text-brand' : 'text-white/40'}`}
                       width="14" height="14" viewBox="0 0 24 24" fill="none"
                       stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  {feat}
                </li>
              ))}
            </ul>

            <a
              href={p('/contact')}
              class={highlight ? 'btn-primary justify-center' : 'btn-outline justify-center'}
            >
              {cta}
            </a>
          </div>
        ))}
      </div>

      <!-- FAQ -->
      <div class="max-w-3xl mx-auto">
        <h2 class="font-display font-bold text-3xl text-center mb-10 animate-on-scroll">
          {t.pricing.faqTitle}
        </h2>
        <div class="space-y-4">
          {t.pricing.faqs.map(({ q, a }, i) => (
            <details
              class="card-glass group animate-on-scroll"
              style={`transition-delay:${i * 60}ms`}
            >
              <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none font-medium text-white/90 hover:text-white">
                {q}
                <svg class="shrink-0 transition-transform duration-300 group-open:rotate-180 text-brand"
                     width="16" height="16" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </summary>
              <p class="px-6 pb-5 text-white/50 text-sm leading-relaxed">{a}</p>
            </details>
          ))}
        </div>
      </div>

    </div>
  </main>

  <Footer lang={lang} />
</Layout>
