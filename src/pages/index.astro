---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import TechBackdrop from '../components/TechBackdrop.astro';
import LatamFlags from '../components/LatamFlags.astro';
import PhoneFrame from '../components/PhoneFrame.astro';
import { useTranslations, localePath } from '../i18n/index';

const lang = 'es';
const t = useTranslations(lang);
const p = (path: string) => localePath(lang, path);

const featureIcons = [
  `<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>`,
  `<circle cx="6" cy="19" r="3"/><path d="M9 19h8.5a3.5 3.5 0 0 0 0-7h-11a3.5 3.5 0 0 1 0-7H15"/><circle cx="18" cy="5" r="3"/>`,
  `<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>`,
  `<path d="M22 2 11 13"/><path d="M22 2 15 22l-4-9-9-4z"/>`,
  `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>`,
  `<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>`,
];

const resultIcons = [
  `<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="m9 16 2 2 4-4"/>`,
  `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>`,
  `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`,
  `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="15" y1="15" x2="9" y2="15"/>`,
  `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  `<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>`,
];
---

<Layout
  title="CGuardPro | Software para Empresas de Seguridad Privada y Gestión de Guardias"
  lang={lang}
  description={t.siteDescription}
>
  <Navbar lang={lang} overVideo />

  <!-- ─── Hero ─────────────────────────────────────────────────────── -->
  <section class="on-video relative overflow-hidden pt-28 lg:pt-36 pb-20 lg:pb-28">
    <video class="absolute inset-0 w-full h-full object-cover" src="/videos/woman-tablet-security.mp4" poster="/videos/woman-tablet-security.jpg" autoplay muted loop playsinline preload="auto" aria-hidden="true"></video>
    <div class="absolute inset-0" style="background:linear-gradient(100deg, rgba(8,8,8,0.94) 0%, rgba(8,8,8,0.86) 45%, rgba(8,8,8,0.7) 100%)" aria-hidden="true"></div>
    <TechBackdrop />

    <div class="relative max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-[1.02fr_1.1fr] gap-14 lg:gap-8 items-center">

        <!-- LEFT: copy -->
        <div class="text-center lg:text-left max-w-xl mx-auto lg:mx-0">
          <span class="section-label animate-fade-in">
            <span class="w-1.5 h-1.5 rounded-full bg-brand animate-pulse inline-block"></span>
            {t.hero.badge}
          </span>
          <h1 class="font-display font-bold text-[2.5rem] sm:text-5xl lg:text-[3.25rem] tracking-tight leading-[1.07] mt-6 mb-5 animate-fade-up" style="animation-delay:.1s">
            {t.hero.headline1}{' '}
            <span class="gold-gradient-text">{t.hero.headline2}</span>
          </h1>
          <p class="text-white/60 text-lg leading-relaxed mb-4 animate-fade-up" style="animation-delay:.2s">
            {t.hero.subheadline}
          </p>
          <p class="text-white/45 text-[15px] leading-relaxed mb-8 animate-fade-up" style="animation-delay:.25s">
            {t.hero.supporting}
          </p>
          <div class="flex flex-col sm:flex-row items-center lg:items-start gap-3 animate-fade-up" style="animation-delay:.3s">
            <a href={p('/contact')} class="btn-primary text-base px-7 py-3.5 w-full sm:w-auto justify-center">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              {t.hero.ctaPrimary}
            </a>
            <a href={p('/#features')} class="btn-outline text-base px-7 py-3.5 w-full sm:w-auto justify-center">
              {t.hero.ctaSecondary}
            </a>
          </div>
          <div class="mt-8 flex flex-wrap items-center justify-center lg:justify-start gap-x-5 gap-y-2 animate-fade-up" style="animation-delay:.4s">
            {[t.hero.trust1, t.hero.trust2, t.hero.trust3].map((x) => (
              <span class="inline-flex items-center gap-1.5 text-white/50 text-sm">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-brand shrink-0"><path d="M20 6 9 17l-5-5"/></svg>
                {x}
              </span>
            ))}
          </div>
        </div>

        <!-- RIGHT: real product screenshot -->
        <div class="relative animate-fade-up lg:pl-2" style="animation-delay:.35s">
          <div class="rounded-2xl overflow-hidden" style="border:1px solid rgba(212,175,55,0.38);box-shadow:0 34px 64px -22px rgba(16,24,40,0.30), 0 12px 24px -14px rgba(16,24,40,0.16)">
            <div class="flex items-center gap-2 px-3.5 py-2.5" style="background:#141414;border-bottom:1px solid rgba(255,255,255,0.06)">
              <div class="flex gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full" style="background:#ff5f56"></span>
                <span class="w-2.5 h-2.5 rounded-full" style="background:#ffbd2e"></span>
                <span class="w-2.5 h-2.5 rounded-full" style="background:#27c93f"></span>
              </div>
              <div class="flex-1 rounded-md px-3 py-1 text-[11px] font-mono mx-2 truncate" style="background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.4)">{t.hero.dashboardUrl}</div>
            </div>
            <img src="/screenshots/dashboard.png" alt={t.hero.dashboardAlt} class="w-full block" width="1600" height="1003" loading="eager" />
          </div>
        </div>

      </div>

      <LatamFlags lang={lang} />
    </div>
  </section>

  <!-- ─── Stats band (product facts) ───────────────────────────────── -->
  <section class="relative py-14 lg:py-16" style="background:var(--surface-2)">
    <div class="gold-line absolute top-0 inset-x-0" aria-hidden="true"></div>
    <div class="gold-line absolute bottom-0 inset-x-0" aria-hidden="true"></div>
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-10 text-center">
        {t.stats.map(({ value, label, sub }) => (
          <div class="animate-on-scroll">
            <div class="font-display font-bold text-4xl lg:text-[2.75rem] leading-none mb-2" style="color:var(--brand)">{value}</div>
            <div class="font-semibold text-sm" style="color:var(--text)">{label}</div>
            <div class="text-xs mt-1" style="color:var(--text-faint)">{sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Problem ──────────────────────────────────────────────────── -->
  <section class="py-20 lg:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-2xl mb-12 lg:mb-14">
        <div class="text-xs font-semibold tracking-[0.15em] uppercase mb-3 animate-on-scroll" style="color:var(--brand)">{t.problem.badge}</div>
        <h2 class="font-display font-bold text-[2rem] lg:text-[2.75rem] leading-[1.1] tracking-tight mb-4 animate-on-scroll" style="color:var(--text)">
          {t.problem.headline}
        </h2>
        <p class="text-lg leading-relaxed animate-on-scroll" style="color:var(--text-muted)">{t.problem.body}</p>
      </div>
      <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {t.problem.bullets.map((item, i) => (
          <li class="flex items-start gap-3 rounded-2xl p-5 animate-on-scroll" style={`background:var(--surface);border:1px solid var(--border);transition-delay:${i * 50}ms`}>
            <span class="mt-0.5 shrink-0 w-5 h-5 rounded-full flex items-center justify-center" style="background:rgba(200,134,10,0.12)">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#C8860A" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            <span class="text-[15px] leading-relaxed" style="color:var(--text-muted)">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ─── Command center (features) ────────────────────────────────── -->
  <section id="features" class="py-20 lg:py-28" style="background:var(--surface-2)">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-2xl mb-12 lg:mb-16">
        <div class="text-xs font-semibold tracking-[0.15em] uppercase mb-3 animate-on-scroll" style="color:var(--brand)">{t.features.badge}</div>
        <h2 class="font-display font-bold text-[2rem] lg:text-[2.75rem] leading-[1.1] tracking-tight mb-4 animate-on-scroll" style="color:var(--text)">
          {t.features.headline1} <span style="color:var(--brand)">{t.features.headline2}</span>
        </h2>
        <p class="text-lg leading-relaxed animate-on-scroll" style="color:var(--text-muted)">{t.features.subheadline}</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {t.features.items.map(({ title, desc }, i) => (
          <article class="rounded-2xl p-6 lg:p-7 transition-all duration-300 hover:-translate-y-1 animate-on-scroll"
                   style={`background:var(--surface);border:1px solid var(--border);box-shadow:var(--card-shadow);transition-delay:${i * 60}ms`}>
            <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5" style="background:rgba(200,134,10,0.10)">
              <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="#C8860A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <Fragment set:html={featureIcons[i]} />
              </svg>
            </div>
            <h3 class="font-display font-semibold text-lg mb-2" style="color:var(--text)">{title}</h3>
            <p class="text-sm leading-relaxed" style="color:var(--text-muted)">{desc}</p>
          </article>
        ))}
      </div>
      <p class="mt-10 max-w-3xl text-[15px] leading-relaxed animate-on-scroll" style="color:var(--text-muted)" set:html={t.features.linksHtml} />
    </div>
  </section>

  <!-- ─── AI ───────────────────────────────────────────────────────── -->
  <section class="py-20 lg:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="animate-on-scroll">
          <div class="text-xs font-semibold tracking-[0.15em] uppercase mb-3" style="color:var(--brand)">{t.ai.badge}</div>
          <h2 class="font-display font-bold text-[2rem] lg:text-[2.6rem] leading-[1.1] tracking-tight mb-5" style="color:var(--text)">
            {t.ai.headline}
          </h2>
          <p class="text-lg leading-relaxed" style="color:var(--text-muted)">{t.ai.body}</p>
        </div>
        <div class="animate-on-scroll">
          <ul class="rounded-2xl p-7 lg:p-8 space-y-4" style="background:var(--surface);border:1px solid var(--border);box-shadow:var(--card-shadow)">
            {t.ai.bullets.map((item) => (
              <li class="flex items-start gap-3 text-[15px]" style="color:var(--text-muted)">
                <span class="mt-0.5 shrink-0 w-5 h-5 rounded-full flex items-center justify-center" style="background:rgba(200,134,10,0.12)">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#C8860A" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Live operations (real screenshot) ────────────────────────── -->
  <section class="py-20 lg:py-28" style="background:var(--surface-2)">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="animate-on-scroll order-2 lg:order-1">
          <div class="rounded-2xl overflow-hidden" style="border:1px solid var(--border);box-shadow:0 34px 64px -24px rgba(16,24,40,0.30),0 12px 24px -14px rgba(16,24,40,0.14)">
            <div class="flex items-center gap-2 px-3.5 py-2.5" style="background:#141414;border-bottom:1px solid rgba(255,255,255,0.06)">
              <div class="flex gap-1.5"><span class="w-2.5 h-2.5 rounded-full" style="background:#ff5f56"></span><span class="w-2.5 h-2.5 rounded-full" style="background:#ffbd2e"></span><span class="w-2.5 h-2.5 rounded-full" style="background:#27c93f"></span></div>
              <div class="flex-1 rounded-md px-3 py-1 text-[11px] font-mono mx-2 truncate" style="background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.4)">{t.liveOps.screenshotUrl}</div>
            </div>
            <img src="/screenshots/incidents.png" alt={t.liveOps.screenshotAlt} class="w-full block" loading="lazy" width="1500" height="940" />
          </div>
        </div>
        <div class="animate-on-scroll order-1 lg:order-2">
          <div class="text-xs font-semibold tracking-[0.15em] uppercase mb-3" style="color:var(--brand)">{t.liveOps.badge}</div>
          <h2 class="font-display font-bold text-[2rem] lg:text-[2.6rem] leading-[1.1] tracking-tight mb-5" style="color:var(--text)">
            {t.liveOps.headline}
          </h2>
          <p class="text-lg leading-relaxed mb-7" style="color:var(--text-muted)">{t.liveOps.body}</p>
          <div class="flex flex-wrap gap-2.5">
            {t.liveOps.alerts.map((alert) => (
              <span class="inline-flex items-center gap-2 rounded-full px-3.5 py-1.5 text-sm" style="background:var(--surface);border:1px solid var(--border);color:var(--text-muted)">
                <span class="w-1.5 h-1.5 rounded-full bg-brand animate-pulse inline-block shrink-0"></span>
                {alert}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Emergency response (video band) ──────────────────────────── -->
  <section class="on-video relative overflow-hidden py-24 lg:py-32">
    <video class="absolute inset-0 w-full h-full object-cover" src="/videos/emergency-vehicle.mp4" poster="/videos/emergency-vehicle.jpg" autoplay muted loop playsinline preload="metadata" aria-hidden="true"></video>
    <div class="absolute inset-0" style="background:linear-gradient(100deg, rgba(8,8,8,0.96) 0%, rgba(8,8,8,0.88) 48%, rgba(8,8,8,0.55) 100%)" aria-hidden="true"></div>
    <div class="relative max-w-6xl mx-auto px-6">
      <div class="max-w-2xl animate-on-scroll rounded-2xl p-8 lg:p-10 -m-2 lg:m-0" style="background:rgba(8,8,8,0.58);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.08)">
        <div class="text-xs font-semibold tracking-[0.15em] uppercase mb-3" style="color:#D4AF37">{t.emergency.badge}</div>
        <h2 class="font-display font-bold text-[2rem] lg:text-[2.6rem] leading-[1.1] tracking-tight mb-5" style="color:#fff">
          {t.emergency.headline}
        </h2>
        <p class="text-lg leading-relaxed mb-8" style="color:rgba(255,255,255,0.78)">{t.emergency.body}</p>
        <ul class="space-y-3.5">
          {t.emergency.bullets.map((item) => (
            <li class="flex items-start gap-3 text-[15px]" style="color:rgba(255,255,255,0.88)">
              <span class="mt-0.5 shrink-0 w-5 h-5 rounded-full flex items-center justify-center" style="background:rgba(212,175,55,0.22)">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ─── Client experience ────────────────────────────────────────── -->
  <section class="py-20 lg:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="animate-on-scroll">
          <div class="text-xs font-semibold tracking-[0.15em] uppercase mb-3" style="color:var(--brand)">{t.clientXp.badge}</div>
          <h2 class="font-display font-bold text-[2rem] lg:text-[2.6rem] leading-[1.1] tracking-tight mb-5" style="color:var(--text)">
            {t.clientXp.headline}
          </h2>
          <p class="text-lg leading-relaxed" style="color:var(--text-muted)">{t.clientXp.body}</p>
        </div>
        <div class="animate-on-scroll">
          <ul class="rounded-2xl p-7 lg:p-8 space-y-4" style="background:var(--surface);border:1px solid var(--border);box-shadow:var(--card-shadow)">
            {t.clientXp.bullets.map((item) => (
              <li class="flex items-start gap-3 text-[15px]" style="color:var(--text-muted)">
                <span class="mt-0.5 shrink-0 w-5 h-5 rounded-full flex items-center justify-center" style="background:rgba(200,134,10,0.12)">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#C8860A" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Mobile app ───────────────────────────────────────────────── -->
  <section class="py-20 lg:py-28" style="background:var(--surface-2)">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-14 lg:gap-10 items-center">
        <div class="animate-on-scroll">
          <div class="text-xs font-semibold tracking-[0.15em] uppercase mb-3" style="color:var(--brand)">{t.mobile.badge}</div>
          <h2 class="font-display font-bold text-[2rem] lg:text-[2.6rem] leading-[1.1] tracking-tight mb-5" style="color:var(--text)">
            {t.mobile.headline1} <span style="color:var(--brand)">{t.mobile.headline2}</span>
          </h2>
          <p class="text-lg leading-relaxed mb-7" style="color:var(--text-muted)">{t.mobile.body}</p>
          <ul class="grid sm:grid-cols-2 gap-x-6 gap-y-3.5 mb-8">
            {t.mobile.features.map((item) => (
              <li class="flex items-start gap-3 text-[15px]" style="color:var(--text-muted)">
                <span class="mt-0.5 shrink-0 w-5 h-5 rounded-full flex items-center justify-center" style="background:rgba(200,134,10,0.12)">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#C8860A" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href={p('/contact')} class="btn-primary">{t.mobile.ctaDemo}</a>
            <a href={t.mobile.ctaLearnHref} class="btn-outline">{t.mobile.ctaLearn}</a>
          </div>
        </div>
        <div class="flex justify-center animate-on-scroll">
          <!-- Real capture of the worker app (same frame as /app-movil) — links to the full tour. -->
          <a
            href={p('/app-movil')}
            class="block w-64 sm:w-72 transition-transform duration-300 hover:-translate-y-1.5 hover:scale-[1.015]"
            aria-label={t.mobile.ctaLearn}
          >
            <PhoneFrame src={`/screenshots/worker-app/${lang}-dashboard.png`} alt={t.workerApp.hero.phoneAlt} />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── How it works ─────────────────────────────────────────────── -->
  <section id="how-it-works" class="py-20 lg:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-2xl mb-14 lg:mb-20">
        <div class="text-xs font-semibold tracking-[0.15em] uppercase mb-3 animate-on-scroll" style="color:var(--brand)">{t.howItWorks.badge}</div>
        <h2 class="font-display font-bold text-[2rem] lg:text-[2.75rem] leading-[1.1] tracking-tight mb-4 animate-on-scroll" style="color:var(--text)">
          {t.howItWorks.headline1} <span style="color:var(--brand)">{t.howItWorks.headline2}</span>
        </h2>
        <p class="text-lg leading-relaxed animate-on-scroll" style="color:var(--text-muted)">
          {lang === 'es' ? 'De la configuración al control total: sin instaladores, sin fricción, en cuatro pasos.' : 'From setup to full command: no installers, no friction, in four steps.'}
        </p>
      </div>

      <div class="relative grid md:grid-cols-2 lg:grid-cols-4 gap-5">
        <!-- connector line (desktop) -->
        <div class="hidden lg:block absolute top-[3.35rem] left-[13%] right-[13%] h-px pointer-events-none" style="background:linear-gradient(90deg, transparent, var(--border-strong) 12%, var(--border-strong) 88%, transparent)" aria-hidden="true"></div>

        {t.howItWorks.steps.map(({ step, title, desc }, i) => (
          <div class="relative rounded-2xl p-6 lg:p-7 animate-on-scroll" style={`background:var(--surface);border:1px solid var(--border-strong);box-shadow:var(--card-shadow);transition-delay:${i * 90}ms`}>
            <div class="flex items-center justify-between mb-6">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center relative z-10" style="background:rgba(200,134,10,0.10);border:1px solid rgba(200,134,10,0.28)">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C8860A" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <Fragment set:html={[
                    '<path d="M3 21h18"/><path d="M5 21V8l7-4 7 4v13"/><path d="M9 21v-6h6v6"/>',
                    '<path d="M17 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"/><circle cx="10" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M17 3.13a4 4 0 0 1 0 7.75"/>',
                    '<rect x="6" y="2" width="12" height="20" rx="2.5"/><path d="M11 18h2"/><path d="M9.5 6.5l2 2 3.5-3.5"/>',
                    '<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/><path d="M6 10l3 3 3-4 3 2 3-4"/>'
                  ][i]} />
                </svg>
              </div>
              <span class="font-display font-extrabold text-[2.6rem] leading-none select-none" style="color:rgba(200,134,10,0.20)">{step}</span>
            </div>
            <h3 class="font-display font-semibold text-lg mb-2" style="color:var(--text)">{title}</h3>
            <p class="text-sm leading-relaxed" style="color:var(--text-muted)">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Why switch ───────────────────────────────────────────────── -->
  <section class="py-20 lg:py-28" style="background:var(--surface-2)">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-2xl mb-12 lg:mb-14">
        <div class="text-xs font-semibold tracking-[0.15em] uppercase mb-3 animate-on-scroll" style="color:var(--brand)">{t.whySwitch.badge}</div>
        <h2 class="font-display font-bold text-[2rem] lg:text-[2.75rem] leading-[1.1] tracking-tight mb-4 animate-on-scroll" style="color:var(--text)">
          {t.whySwitch.headline}
        </h2>
        <p class="text-lg leading-relaxed animate-on-scroll" style="color:var(--text-muted)">{t.whySwitch.body}</p>
      </div>
      <ul class="grid sm:grid-cols-2 gap-x-10 gap-y-4 max-w-4xl">
        {t.whySwitch.bullets.map((item) => (
          <li class="flex items-start gap-3 text-[15px] animate-on-scroll" style="color:var(--text-muted)">
            <span class="mt-0.5 shrink-0 w-5 h-5 rounded-full flex items-center justify-center" style="background:rgba(200,134,10,0.12)">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#C8860A" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ─── Results ──────────────────────────────────────────────────── -->
  <section class="py-20 lg:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-2xl mb-12 lg:mb-16">
        <div class="text-xs font-semibold tracking-[0.15em] uppercase mb-3 animate-on-scroll" style="color:var(--brand)">{t.results.badge}</div>
        <h2 class="font-display font-bold text-[2rem] lg:text-[2.75rem] leading-[1.1] tracking-tight mb-4 animate-on-scroll" style="color:var(--text)">
          {t.results.headline}
        </h2>
        <p class="text-lg leading-relaxed animate-on-scroll" style="color:var(--text-muted)">{t.results.body}</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {t.results.cards.map((title, i) => (
          <div class="flex items-center gap-4 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 animate-on-scroll"
               style={`background:var(--surface);border:1px solid var(--border);box-shadow:var(--card-shadow);transition-delay:${i * 60}ms`}>
            <div class="w-11 h-11 shrink-0 rounded-xl flex items-center justify-center" style="background:rgba(200,134,10,0.10)">
              <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="#C8860A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <Fragment set:html={resultIcons[i]} />
              </svg>
            </div>
            <h3 class="font-display font-semibold text-[16px] leading-snug" style="color:var(--text)">{title}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Final CTA (dark band) ────────────────────────────────────── -->
  <section class="py-20 lg:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <div class="on-video relative rounded-3xl px-8 py-16 lg:py-20 text-center overflow-hidden animate-on-scroll" style="background:#141414;border:1px solid rgba(212,175,55,0.28)">
        <div class="gold-line absolute top-0 inset-x-0" aria-hidden="true"></div>
        <div class="relative">
          <h2 class="font-display font-bold text-3xl lg:text-[2.75rem] leading-tight tracking-tight mb-4" style="color:#fff">{t.cta.headline}</h2>
          <p class="text-lg max-w-2xl mx-auto mb-9" style="color:rgba(255,255,255,0.68)">{t.cta.subheadline}</p>
          <div class="flex flex-col sm:flex-row justify-center gap-3">
            <a href={p('/contact')} class="btn-primary text-base px-8 py-3.5 justify-center">{t.cta.primary}</a>
            <a href={p('/#how-it-works')} class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-lg font-semibold text-base transition-colors" style="border:1px solid rgba(255,255,255,0.22);color:#fff">{t.cta.secondary}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer lang={lang} />
</Layout>
