---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const lang = 'es';
const sector = 'Parques Industriales';
const description = `Software de seguridad para parques industriales, bodegas y zonas francas en Ecuador. CGuardPro gestiona guardias, rondas perimetrales, control de acceso vehicular y seguridad industrial.`;
---

<Layout
  title={`Seguridad para ${sector} — CGuardPro`}
  lang={lang}
  description={description}
>
  <Navbar lang={lang} />

  <main class="pt-32 pb-24">
    <div class="max-w-7xl mx-auto px-6">

      <!-- Hero -->
      <div class="text-center mb-20">
        <span class="section-label mb-4 inline-flex">{sector}</span>
        <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl mb-6 animate-on-scroll leading-tight">
          Seguridad Industrial para<br />
          <span class="text-brand">{sector}</span>
        </h1>
        <p class="text-white/60 text-lg max-w-2xl mx-auto mb-10 animate-on-scroll">
          Parques industriales, bodegas, centros logísticos y zonas francas manejan inventario de alto valor y operan las 24 horas. CGuardPro proporciona control total sobre rondas, accesos y documentación de incidentes en entornos industriales.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center animate-on-scroll">
          <a href="/contact" class="btn-primary">Solicitar Demo Gratis</a>
          <a href="/pricing" class="btn-outline">Ver Precios</a>
        </div>
      </div>

      <!-- Desafíos -->
      <section class="mb-20">
        <h2 class="font-display font-bold text-3xl text-center mb-12 animate-on-scroll">
          Desafíos de Seguridad Industrial
        </h2>
        <div class="grid md:grid-cols-3 gap-8">
          {[
            { title: 'Perímetros Extensos', desc: 'Parques industriales con kilómetros de cerco perimetral, múltiples accesos vehiculares, y áreas remotas difíciles de monitorear.' },
            { title: 'Control de Carga', desc: 'Camiones entrando y saliendo 24/7. Verificación de sellos, documentación de carga, y control de conductores y acompañantes.' },
            { title: 'Múltiples Empresas', desc: 'Un parque industrial alberga decenas de empresas. Cada una con requisitos diferentes de seguridad y acceso para su personal.' },
          ].map(({ title, desc }) => (
            <div class="card-glass p-6 animate-on-scroll">
              <h3 class="font-display font-semibold text-lg text-white mb-2">{title}</h3>
              <p class="text-white/50 text-sm leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Solución -->
      <section class="mb-20">
        <h2 class="font-display font-bold text-3xl text-center mb-12 animate-on-scroll">
          CGuardPro para Entornos Industriales
        </h2>
        <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
          {[
            { feature: 'Rondas Perimetrales GPS', desc: 'Checkpoints en todo el perímetro con ventanas de tiempo. Alerta si el guardia no completa la ronda en el tiempo establecido.' },
            { feature: 'Control de Acceso Vehicular', desc: 'Registra cada vehículo: placa, conductor, empresa, hora de entrada/salida, tipo de carga. Historial completo y consultable.' },
            { feature: 'Verificación de Sellos', desc: 'Documenta sellos de seguridad de camiones con fotos. Compara al ingreso y egreso para detectar manipulación.' },
            { feature: 'Geofencing por Zona', desc: 'Define zonas dentro del parque industrial. Alerta cuando un guardia sale de su zona asignada o no visita un área requerida.' },
            { feature: 'Reportes por Empresa', desc: 'Genera reportes individuales para cada empresa del parque. Cada inquilino ve solo la información de su área.' },
            { feature: 'Operación Nocturna', desc: 'App optimizada para turnos nocturnos. Modo oscuro, bajo consumo de batería, y funcionamiento offline en áreas sin cobertura.' },
          ].map(({ feature, desc }) => (
            <div class="flex gap-4 animate-on-scroll">
              <div class="w-6 h-6 rounded-full bg-brand/20 flex items-center justify-center shrink-0 mt-0.5">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#C8860A" stroke-width="3">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </div>
              <div>
                <h3 class="font-medium text-white mb-1">{feature}</h3>
                <p class="text-white/50 text-sm">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Tipos de sitio -->
      <section class="mb-20">
        <h2 class="font-display font-bold text-3xl text-center mb-12 animate-on-scroll">
          Tipos de Instalaciones que Protegemos
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
          {['Parques industriales', 'Centros logísticos', 'Bodegas y almacenes', 'Zonas francas', 'Plantas de producción', 'Centros de distribución', 'Terminales de carga', 'Puertos secos'].map((tipo) => (
            <div class="card-glass p-4 text-center animate-on-scroll">
              <span class="text-white/70 text-sm">{tipo}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- CTA -->
      <section class="text-center card-glass p-12 rounded-2xl animate-on-scroll">
        <h2 class="font-display font-bold text-3xl mb-4">
          ¿Brindas seguridad industrial?
        </h2>
        <p class="text-white/60 mb-8 max-w-xl mx-auto">
          Demuestra a tus clientes industriales que cada ronda se cumple y cada acceso se registra. Solicita tu demo gratuita.
        </p>
        <a href="/contact" class="btn-primary text-lg px-8 py-4">
          Solicitar Demo Gratis
        </a>
      </section>

    </div>
  </main>

  <Footer lang={lang} />
</Layout>
