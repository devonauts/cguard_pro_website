---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const lang = 'es';
const sector = 'Instituciones Educativas';
const description = `Software de seguridad para colegios, universidades e instituciones educativas en Ecuador. CGuardPro gestiona guardias, control de acceso estudiantil, rondas y reportes de seguridad escolar.`;
---

<Layout
  title={`Seguridad para ${sector} — CGuardPro`}
  lang={lang}
  description={description}
>
  <Navbar lang={lang} />

  <main class="pt-32 pb-24">
    <div class="max-w-7xl mx-auto px-6">

      <!-- Hero -->
      <div class="text-center mb-20">
        <span class="section-label mb-4 inline-flex">{sector}</span>
        <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl mb-6 animate-on-scroll leading-tight">
          Seguridad Especializada para<br />
          <span class="text-brand">{sector}</span>
        </h1>
        <p class="text-white/60 text-lg max-w-2xl mx-auto mb-10 animate-on-scroll">
          Colegios, universidades y centros educativos tienen la responsabilidad de proteger a estudiantes, docentes y personal. CGuardPro permite ofrecer seguridad verificable y profesional en entornos educativos.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center animate-on-scroll">
          <a href="/contact" class="btn-primary">Solicitar Demo Gratis</a>
          <a href="/pricing" class="btn-outline">Ver Precios</a>
        </div>
      </div>

      <!-- Desafíos -->
      <section class="mb-20">
        <h2 class="font-display font-bold text-3xl text-center mb-12 animate-on-scroll">
          Desafíos de Seguridad Educativa
        </h2>
        <div class="grid md:grid-cols-3 gap-8">
          {[
            { title: 'Protección de Menores', desc: 'La seguridad de estudiantes es la máxima prioridad. Control estricto de quién entra y sale, especialmente en horarios de ingreso y salida.' },
            { title: 'Campus Extensos', desc: 'Universidades con múltiples edificios, estacionamientos, áreas deportivas y zonas verdes que requieren cobertura completa.' },
            { title: 'Horarios Variables', desc: 'Turnos matutinos, vespertinos, nocturnos (universidades), eventos especiales, fines de semana. La seguridad se adapta al calendario académico.' },
          ].map(({ title, desc }) => (
            <div class="card-glass p-6 animate-on-scroll">
              <h3 class="font-display font-semibold text-lg text-white mb-2">{title}</h3>
              <p class="text-white/50 text-sm leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Solución -->
      <section class="mb-20">
        <h2 class="font-display font-bold text-3xl text-center mb-12 animate-on-scroll">
          CGuardPro para Seguridad Educativa
        </h2>
        <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
          {[
            { feature: 'Control de Acceso Estudiantil', desc: 'Registro de entrada y salida de estudiantes. Control de personas autorizadas para retirar menores. Alertas ante irregularidades.' },
            { feature: 'Rondas en Campus', desc: 'Checkpoints en edificios, estacionamientos, áreas deportivas y perímetro. Verificación de que cada zona es visitada según horario.' },
            { feature: 'Reporte de Incidentes Escolar', desc: 'Documentación de peleas, acoso, personas sospechosas, daños a propiedad. Fotos, ubicación y notificación inmediata a la dirección.' },
            { feature: 'Portal para la Dirección', desc: 'El rector o director de seguridad ve actividad en tiempo real: presencia de guardias, incidentes del día, y estadísticas semanales.' },
            { feature: 'Gestión de Eventos', desc: 'Graduaciones, competencias deportivas, ferias. Programa guardias adicionales y verifica su presencia en puntos estratégicos.' },
            { feature: 'Registro de Visitantes', desc: 'Padres de familia, proveedores y visitantes registrados con foto y motivo. Nadie entra sin documentación.' },
          ].map(({ feature, desc }) => (
            <div class="flex gap-4 animate-on-scroll">
              <div class="w-6 h-6 rounded-full bg-brand/20 flex items-center justify-center shrink-0 mt-0.5">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#C8860A" stroke-width="3">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </div>
              <div>
                <h3 class="font-medium text-white mb-1">{feature}</h3>
                <p class="text-white/50 text-sm">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Tipos -->
      <section class="mb-20">
        <h2 class="font-display font-bold text-3xl text-center mb-12 animate-on-scroll">
          Instituciones que Protegemos
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
          {['Colegios privados', 'Universidades', 'Escuelas bilingües', 'Institutos técnicos', 'Guarderías', 'Centros de formación', 'Campus universitarios', 'Centros deportivos'].map((tipo) => (
            <div class="card-glass p-4 text-center animate-on-scroll">
              <span class="text-white/70 text-sm">{tipo}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- CTA -->
      <section class="text-center card-glass p-12 rounded-2xl animate-on-scroll">
        <h2 class="font-display font-bold text-3xl mb-4">
          ¿Brindas seguridad a instituciones educativas?
        </h2>
        <p class="text-white/60 mb-8 max-w-xl mx-auto">
          Demuestra a directivos y padres de familia que la seguridad se cumple al 100%. Demo gratuita disponible.
        </p>
        <a href="/contact" class="btn-primary text-lg px-8 py-4">
          Solicitar Demo Gratis
        </a>
      </section>

    </div>
  </main>

  <Footer lang={lang} />
</Layout>
