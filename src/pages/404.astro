---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="404 — Page Not Found" noIndex={true}>
  <Navbar />
  <main class="min-h-screen flex items-center justify-center px-6 pt-20">
    <div class="text-center">
      <div class="font-mono text-brand text-sm mb-4 tracking-widest">// ERROR 404</div>
      <h1 class="font-display font-bold text-8xl text-white/10 mb-4">404</h1>
      <h2 class="font-display font-bold text-3xl mb-4">Page not found</h2>
      <p class="text-white/50 mb-8 max-w-sm mx-auto">The page you're looking for doesn't exist or has been moved.</p>
      <a href="/" class="btn-primary">Return to Home</a>
    </div>
  </main>
  <Footer />
</Layout>
