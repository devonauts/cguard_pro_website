---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const lang = 'es';
const city = 'Guayaquil';
const description = `Software de gestión de seguridad privada en ${city}. CGuardPro ayuda a empresas de seguridad en ${city} a gestionar guardias, turnos, rondas GPS e incidentes desde una sola plataforma.`;
---

<Layout
  hasAlternate={false}
  title={`Software de Seguridad Privada en ${city} — CGuardPro`}
  lang={lang}
  description={description}
>
  <Navbar lang={lang} />

  <main class="pt-32 pb-24">
    <div class="max-w-7xl mx-auto px-6">

      <!-- Hero -->
      <div class="text-center mb-20">
        <span class="section-label mb-4 inline-flex">{city}, Ecuador</span>
        <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl mb-6 animate-on-scroll leading-tight">
          Gestión de Seguridad Privada<br />
          <span class="text-brand">en {city}</span>
        </h1>
        <p class="text-white/60 text-lg max-w-2xl mx-auto mb-10 animate-on-scroll">
          CGuardPro es la plataforma preferida por empresas de seguridad en {city}. Gestiona operaciones 24/7 en zonas comerciales, portuarias y residenciales con GPS tracking, reportes digitales y portal de clientes.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center animate-on-scroll">
          <a href="/contact" class="btn-primary">Solicitar Demo Gratis</a>
          <a href="/pricing" class="btn-outline">Ver Precios</a>
        </div>
      </div>

      <!-- Local Context -->
      <section class="mb-20">
        <h2 class="font-display font-bold text-3xl text-center mb-12 animate-on-scroll">
          ¿Por qué empresas de seguridad en {city} eligen CGuardPro?
        </h2>
        <div class="grid md:grid-cols-3 gap-8">
          {[
            { title: 'Operación en Clima Extremo', desc: `Diseñado para funcionar en las condiciones de ${city}. App que no consume batería excesiva y funciona en turnos completos bajo el sol del trópico.` },
            { title: 'Cobertura Puerto a Samborondón', desc: `Gestiona sitios desde la zona portuaria hasta Samborondón, Durán y vía a la costa. Un panel para toda el área metropolitana.` },
            { title: 'Respuesta Rápida Documentada', desc: `En ${city}, la velocidad de respuesta es crítica. CGuardPro documenta tiempos de reacción y genera evidencia para tus clientes.` },
          ].map(({ title, desc }) => (
            <div class="card-glass p-6 animate-on-scroll">
              <h3 class="font-display font-semibold text-lg text-white mb-2">{title}</h3>
              <p class="text-white/50 text-sm leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Features -->
      <section class="mb-20">
        <h2 class="font-display font-bold text-3xl text-center mb-12 animate-on-scroll">
          Funcionalidades clave para operar en {city}
        </h2>
        <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
          {[
            { feature: 'Control de asistencia GPS', desc: 'Fichaje automático con geofencing. Verifica que el guardia está en el sitio asignado.' },
            { feature: 'Rondas con puntos de control', desc: 'Checkpoints configurables para bodegas, perímetros y zonas de carga.' },
            { feature: 'Reporte de incidentes inmediato', desc: 'Documentación fotográfica instantánea con coordenadas GPS y hora exacta.' },
            { feature: 'Programación de turnos 24/7', desc: 'Gestiona cobertura continua con rotaciones que cumplen la ley laboral.' },
            { feature: 'Portal para clientes', desc: 'Acceso directo a reportes y métricas. Ideal para clientes corporativos exigentes.' },
            { feature: 'Modo offline', desc: 'Funciona sin internet en bodegas, sótanos y zonas industriales. Sincroniza después.' },
          ].map(({ feature, desc }) => (
            <div class="flex gap-4 animate-on-scroll">
              <div class="w-6 h-6 rounded-full bg-brand/20 flex items-center justify-center shrink-0 mt-0.5">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#C8860A" stroke-width="3">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </div>
              <div>
                <h3 class="font-medium text-white mb-1">{feature}</h3>
                <p class="text-white/50 text-sm">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Sectors -->
      <section class="mb-20">
        <h2 class="font-display font-bold text-3xl text-center mb-12 animate-on-scroll">
          Sectores que servimos en {city}
        </h2>
        <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto">
          {[
            { n: 'Zona portuaria y logística', h: '/seguridad-parques-industriales' },
            { n: 'Centros comerciales', h: '/seguridad-centros-comerciales' },
            { n: 'Urbanizaciones cerradas', h: '/seguridad-urbanizaciones-residenciales' },
            { n: 'Bodegas industriales', h: '/seguridad-parques-industriales' },
            { n: 'Sector bananero', h: null },
            { n: 'Cadenas de retail', h: '/seguridad-centros-comerciales' },
            { n: 'Hospitales y clínicas', h: '/seguridad-hospitales-clinicas' },
            { n: 'Instituciones financieras', h: '/seguridad-sector-financiero' },
          ].map((sector) => (
            sector.h ? (
              <a href={sector.h} class="card-glass px-4 py-3 text-center text-sm text-white/70 animate-on-scroll transition-colors hover:text-white block">{sector.n}</a>
            ) : (
              <div class="card-glass px-4 py-3 text-center text-sm text-white/70 animate-on-scroll">{sector.n}</div>
            )
          ))}
        </div>
      </section>

      <!-- CTA -->
      <section class="text-center card-glass p-12 rounded-2xl animate-on-scroll">
        <h2 class="font-display font-bold text-3xl mb-4">
          ¿Listo para modernizar tu operación en {city}?
        </h2>
        <p class="text-white/50 text-lg mb-8 max-w-xl mx-auto">
          Únete a las empresas de seguridad en {city} que ya gestionan todo con CGuardPro. Prueba gratis por 14 días.
        </p>
        <a href="/contact" class="btn-primary">Comenzar Prueba Gratis</a>
      </section>

    </div>
  </main>

  <Footer lang={lang} />
</Layout>
