---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { useTranslations, localePath } from '../i18n/index';

const lang = 'es';
const t = useTranslations(lang);
const p = (path: string) => localePath(lang, path);
---

<Layout
  title="Agenda una Demo del Software de Seguridad"
  lang={lang}
  description="Solicita una demo en vivo de CGuardPro: mira cómo gestionar vigilantes, turnos, rondas e incidentes en una sola plataforma. Respuesta el mismo día."
>
  <Navbar lang={lang} />

  <main class="pt-32 pb-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-start">

        <!-- Left column -->
        <div>
          <span class="section-label mb-6 inline-flex">{t.contact.badge}</span>
          <h1 class="font-display font-bold text-5xl mb-6 leading-tight animate-on-scroll">
            {t.contact.headline1}<br />
            <span class="text-brand">{t.contact.headline2}</span>
          </h1>
          <p class="text-white/60 text-lg leading-relaxed mb-10 animate-on-scroll">
            {t.contact.subheadline}
          </p>

          <div class="space-y-6 animate-on-scroll">
            {[
              { icon: `<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.65 3.42 2 2 0 0 1 3.62 1.24h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.84a16 16 0 0 0 6.29 6.29l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>`, label: t.contact.phone, value: '+593 99 591-4128', href: 'tel:+593995914128' },
              { icon: `<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>`, label: t.contact.email, value: 'sales@cguardpro.com', href: 'mailto:sales@cguardpro.com' },
            ].map(({ icon, label, value, href }) => (
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-xl bg-brand/10 border border-brand/20 flex items-center justify-center shrink-0">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C8860A" stroke-width="1.5"
                       stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <Fragment set:html={icon} />
                  </svg>
                </div>
                <div>
                  <div class="text-white/40 text-xs">{label}</div>
                  <a href={href} class="text-white font-medium hover:text-brand transition-colors">{value}</a>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Form -->
        <div class="card-glass p-8 rounded-2xl animate-on-scroll">
          <h2 class="font-display font-semibold text-xl mb-6">{t.contact.formTitle}</h2>
          <form id="contact-form" class="space-y-5" novalidate
               data-submitting={t.contact.submitting}
               data-success={t.contact.successMsg}>
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="firstName" class="block text-sm text-white/60 mb-1.5">{t.contact.firstName} <span class="text-brand">{t.contact.required}</span></label>
                <input id="firstName" name="firstName" type="text" required autocomplete="given-name"
                       class="w-full bg-navy/60 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/20
                              focus:outline-none focus:border-brand/50 focus:ring-1 focus:ring-brand/30 transition-colors text-sm"
                       placeholder={t.contact.firstNamePlaceholder} />
              </div>
              <div>
                <label for="lastName" class="block text-sm text-white/60 mb-1.5">{t.contact.lastName} <span class="text-brand">{t.contact.required}</span></label>
                <input id="lastName" name="lastName" type="text" required autocomplete="family-name"
                       class="w-full bg-navy/60 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/20
                              focus:outline-none focus:border-brand/50 focus:ring-1 focus:ring-brand/30 transition-colors text-sm"
                       placeholder={t.contact.lastNamePlaceholder} />
              </div>
            </div>

            <div>
              <label for="email" class="block text-sm text-white/60 mb-1.5">{t.contact.workEmail} <span class="text-brand">{t.contact.required}</span></label>
              <input id="email" name="email" type="email" required autocomplete="email"
                     class="w-full bg-navy/60 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/20
                            focus:outline-none focus:border-brand/50 focus:ring-1 focus:ring-brand/30 transition-colors text-sm"
                     placeholder={t.contact.emailPlaceholder} />
            </div>

            <div>
              <label for="company" class="block text-sm text-white/60 mb-1.5">{t.contact.company} <span class="text-brand">{t.contact.required}</span></label>
              <input id="company" name="company" type="text" required autocomplete="organization"
                     class="w-full bg-navy/60 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/20
                            focus:outline-none focus:border-brand/50 focus:ring-1 focus:ring-brand/30 transition-colors text-sm"
                     placeholder={t.contact.companyPlaceholder} />
            </div>

            <div>
              <label for="guards" class="block text-sm text-white/60 mb-1.5">{t.contact.guards}</label>
              <select id="guards" name="guards"
                      class="w-full bg-navy/60 border border-white/10 rounded-xl px-4 py-3 text-white/80
                             focus:outline-none focus:border-brand/50 focus:ring-1 focus:ring-brand/30 transition-colors text-sm">
                <option value="">{t.contact.guardsPlaceholder}</option>
                {t.contact.guardsOptions.map((opt, i) => (
                  <option value={['1-10','11-50','51-150','150+'][i]}>{opt}</option>
                ))}
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm text-white/60 mb-1.5">{t.contact.message}</label>
              <textarea id="message" name="message" rows="3"
                        class="w-full bg-navy/60 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/20
                               focus:outline-none focus:border-brand/50 focus:ring-1 focus:ring-brand/30 transition-colors text-sm resize-none"
                        placeholder={t.contact.messagePlaceholder}></textarea>
            </div>

            <button type="submit" class="btn-primary w-full justify-center text-base py-3.5">
              <span id="btn-text">{t.contact.submit}</span>
              <svg id="btn-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </button>

            <p id="form-msg" class="text-center text-sm hidden"></p>
          </form>
        </div>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btnText = document.getElementById('btn-text')!;
  const formMsg = document.getElementById('form-msg')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btnText.textContent = btnText.closest('form')?.dataset.submitting ?? 'Sending…';

    await new Promise(r => setTimeout(r, 1000));

    form.reset();
    btn.disabled = false;
    formMsg.textContent = form.dataset.success ?? '✓ Sent!';
    formMsg.className = 'text-center text-sm text-brand';
  });
</script>

