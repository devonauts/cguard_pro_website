---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  // ES posts only: without this filter every EN post was ALSO built under the
  // Spanish /blog/ path — 12 duplicate, self-canonical, indexable URLs
  // (the EN tree at /en/blog/[slug] already filters lang === 'en').
  const posts = (await getCollection('blog')).filter((p) => p.data.lang === 'es');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const lang = post.data.lang || 'es';
---

<Layout
  title={post.data.title}
  lang={lang}
  description={post.data.description}
  image={post.data.image || '/og-image.jpg'}
>
  <Navbar lang={lang} />

  <!-- Article Structured Data -->
  <Fragment set:html={`<script type="application/ld+json">${JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": post.data.title,
    "description": post.data.description,
    ...(post.data.image ? { "image": `https://cguardpro.com${post.data.image}` } : {}),
    "datePublished": post.data.pubDate.toISOString(),
    "dateModified": (post.data.updatedDate || post.data.pubDate).toISOString(),
    "author": {
      "@type": "Organization",
      "name": post.data.author || "CGuardPro",
      "url": "https://cguardpro.com"
    },
    "publisher": {
      "@type": "Organization",
      "name": "CGuardPro",
      "url": "https://cguardpro.com",
      "logo": { "@type": "ImageObject", "url": "https://cguardpro.com/logo.png" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": `https://cguardpro.com/blog/${post.id}/` },
    "inLanguage": lang === "es" ? "es-EC" : "en"
  })}</script>`} />

  <!-- Breadcrumb Schema -->
  <Fragment set:html={`<script type="application/ld+json">${JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://cguardpro.com/" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://cguardpro.com/blog/" },
      { "@type": "ListItem", "position": 3, "name": post.data.title }
    ]
  })}</script>`} />

  <main class="pt-32 pb-24">
    <article class="max-w-3xl mx-auto px-6">

      <!-- Breadcrumb -->
      <nav class="mb-8 text-sm text-white/40" aria-label="Breadcrumb">
        <a href="/" class="hover:text-brand transition-colors">Inicio</a>
        <span class="mx-2">/</span>
        <a href="/blog/" class="hover:text-brand transition-colors">Blog</a>
        <span class="mx-2">/</span>
        <span class="text-white/60">{post.data.title}</span>
      </nav>

      <!-- Header -->
      <header class="mb-12">
        <div class="flex items-center gap-3 mb-4">
          <time class="text-sm text-white/40 font-mono" datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString(lang === 'es' ? 'es-EC' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {post.data.tags.map(tag => (
            <span class="text-xs bg-brand/10 text-brand px-2 py-0.5 rounded-full">{tag}</span>
          ))}
        </div>
        <h1 class="font-display font-bold text-4xl sm:text-5xl leading-tight mb-4">
          {post.data.title}
        </h1>
        <p class="text-white/60 text-lg leading-relaxed">
          {post.data.description}
        </p>
      </header>

      {post.data.image && (
        <img
          src={post.data.image}
          alt={post.data.title}
          width="1200"
          height="630"
          class="w-full rounded-2xl mb-12"
          style="border:1px solid var(--border)"
          loading="eager"
          decoding="async"
        />
      )}

      <!-- Content -->
      <div class="prose prose-invert prose-brand max-w-none
                  prose-headings:font-display prose-headings:font-semibold
                  prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
                  prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
                  prose-p:text-white/70 prose-p:leading-relaxed
                  prose-li:text-white/70
                  prose-strong:text-white prose-strong:font-semibold
                  prose-a:text-brand prose-a:no-underline hover:prose-a:underline">
        <Content />
      </div>

      <!-- CTA -->
      <div class="mt-16 p-8 card-glass text-center rounded-2xl">
        <h2 class="font-display font-bold text-2xl mb-3">¿Listo para modernizar tu operación?</h2>
        <p class="text-white/50 mb-6">Prueba CGuardPro gratis por 14 días. Sin tarjeta de crédito.</p>
        <a href="/contact" class="btn-primary inline-flex">Solicitar Demo</a>
      </div>

    </article>
  </main>

  <Footer lang={lang} />
</Layout>
