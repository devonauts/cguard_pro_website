---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const lang = 'es';
const posts = (await getCollection('blog'))
  .filter(post => post.data.lang === 'es')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title="Blog — Gestión de Seguridad Privada en Ecuador"
  lang={lang}
  description="Artículos, guías y recursos sobre gestión de seguridad privada, tecnología para empresas de seguridad y mejores prácticas del sector en Ecuador."
>
  <Navbar lang={lang} />

  <main class="pt-32 pb-24">
    <div class="max-w-7xl mx-auto px-6">

      <!-- Header -->
      <div class="text-center mb-16">
        <span class="section-label mb-4 inline-flex">Blog</span>
        <h1 class="font-display font-bold text-5xl mb-4 animate-on-scroll">
          Recursos para Empresas<br />
          <span class="text-brand">de Seguridad</span>
        </h1>
        <p class="text-white/50 text-lg max-w-xl mx-auto animate-on-scroll">
          Guías prácticas, tendencias del sector y consejos para digitalizar y hacer crecer tu empresa de seguridad en Ecuador.
        </p>
      </div>

      <!-- Blog Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <a href={`/blog/${post.id}/`} class="card-glass group hover:border-brand/30 transition-all duration-300 animate-on-scroll">
            {post.data.image && (
              <img src={post.data.image} alt="" width="1200" height="630" class="w-full rounded-t-[inherit]" loading="lazy" decoding="async" />
            )}
            <div class="p-6">
              <div class="flex items-center gap-2 mb-3">
                <time class="text-xs text-white/40 font-mono">
                  {post.data.pubDate.toLocaleDateString('es-EC', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
                {post.data.tags.slice(0, 2).map(tag => (
                  <span class="text-xs bg-brand/10 text-brand px-2 py-0.5 rounded-full">{tag}</span>
                ))}
              </div>
              <h2 class="font-display font-semibold text-lg text-white group-hover:text-brand transition-colors mb-2 line-clamp-2">
                {post.data.title}
              </h2>
              <p class="text-white/50 text-sm line-clamp-3">
                {post.data.description}
              </p>
              <div class="mt-4 text-brand text-sm font-medium flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                Leer más
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>

    </div>
  </main>

  <Footer lang={lang} />
</Layout>
