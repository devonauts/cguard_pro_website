---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
const lang = 'es';

const rows = [
  { c: 'Idioma de la plataforma y del soporte', cg: 'Español nativo (plataforma, apps y soporte)', gp: 'Inglés; sin versión localizada para LATAM' },
  { c: 'Terminología LATAM (novedades, sacafrancos, rondines)', cg: 'Nativa — no es una traducción', gp: 'No aplica' },
  { c: 'Radio PTT integrada', cg: 'Sí — canal de voz en la app, sin comprar radios', gp: 'No es su enfoque' },
  { c: 'Botón de pánico del cliente final', cg: 'Sí — SOS del cliente dispara tu central', gp: 'Orientado al guardia' },
  { c: 'Pase de turno automático (relevo con novedades)', cg: 'Sí', gp: 'Reportes por turno' },
  { c: 'Turnos 24x24 / 12x12 con sacafrancos', cg: 'Motor nativo de rotaciones LATAM', gp: 'Scheduling generalista' },
  { c: 'Rondas', cg: 'QR/NFC con verificación GPS en servidor', gp: 'Guard tour con checkpoints' },
  { c: 'Portal del cliente', cg: 'Incluido, con app móvil para el cliente', gp: 'Portal disponible' },
  { c: 'Soporte en tu zona horaria', cg: 'Sí, en español', gp: 'Horario y idioma de EE.UU./India' },
];

const faqs = [
  { q: '¿Por qué buscar una alternativa a GuardsPro en América Latina?', a: 'GuardsPro es un producto correcto para el mercado angloparlante, pero no tiene versión en español ni vocabulario LATAM: tu personal operativo termina usando una app en inglés y tu central adaptando procesos ajenos. CGuardPro está escrito desde la operación latinoamericana: novedades, relevos, sacafrancos y rondines nativos.' },
  { q: '¿CGuardPro cubre lo mismo que GuardsPro?', a: 'El núcleo operativo completo: app del guardia, rondas verificadas, asistencia con selfie y GPS, turnos, reportes de incidentes, supervisión en mapa y portal del cliente — y añade radio PTT integrada y SOS del cliente final, que no son el enfoque de GuardsPro.' },
  { q: '¿Cómo se comparan los precios?', a: 'CGuardPro publica precios por puesto en su página de precios, sin cotizaciones a ciegas. GuardsPro publica planes por guardia/mes en directorios como Capterra; verifica los valores vigentes con el proveedor.' },
  { q: '¿Qué tan difícil es migrar?', a: 'La implementación típica toma días: puestos, guardias y turnos se cargan desde el panel, los códigos QR se imprimen y el personal instala la app en sus celulares. Sin hardware propietario.' },
];
---

<Layout
  hasAlternate={false}
  title="Alternativa a GuardsPro en Español — CGuardPro"
  lang={lang}
  description="¿Buscas una alternativa a GuardsPro en español? CGuardPro cubre el mismo núcleo — app del guardia, rondas, turnos, incidentes, portal del cliente — con radio PTT, SOS del cliente y terminología LATAM nativa."
>
  <Navbar lang={lang} />

  <Fragment set:html={`<script type="application/ld+json">${JSON.stringify({
    '@context': 'https://schema.org', '@type': 'FAQPage',
    mainEntity: faqs.map(({ q, a }) => ({ '@type': 'Question', name: q, acceptedAnswer: { '@type': 'Answer', text: a } })),
  })}</script>`} />

  <main class="pt-28 lg:pt-32 pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <span class="section-label mb-5 inline-flex">Comparativa</span>
      <h1 class="font-display font-bold text-[2.3rem] lg:text-[3rem] leading-[1.08] tracking-tight">
        Alternativa a GuardsPro<br /><span class="gold-gradient-text">hecha para América Latina</span>
      </h1>
      <p class="mt-6 text-lg leading-relaxed max-w-2xl" style="color:var(--text-muted)">
        Si tu operación vive en español — novedades, relevos, rondines, sacafrancos —
        una plataforma en inglés siempre va a quedar a medio camino. Esta es la
        comparación honesta.
      </p>

      <div class="mt-12 overflow-x-auto rounded-2xl" style="border:1px solid var(--border)">
        <table class="w-full text-sm" style="background:var(--surface)">
          <thead>
            <tr style="border-bottom:1px solid var(--border)">
              <th class="text-left p-4 font-semibold" style="color:var(--text-faint)"></th>
              <th class="text-left p-4 font-semibold" style="color:var(--brand)">CGuardPro</th>
              <th class="text-left p-4 font-semibold">GuardsPro</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((r) => (
              <tr style="border-bottom:1px solid var(--border)">
                <td class="p-4 font-medium">{r.c}</td>
                <td class="p-4" style="color:var(--text-muted)">{r.cg}</td>
                <td class="p-4" style="color:var(--text-muted)">{r.gp}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-3 text-xs" style="color:var(--text-faint)">
        Información sobre GuardsPro basada en su sitio público y en directorios de
        software (Capterra) a la fecha de publicación; verifica con el proveedor.
        GuardsPro es una marca de su respectivo propietario.
      </p>

      <div class="mt-14 space-y-4">
        <h2 class="font-display font-bold text-2xl mb-6">Preguntas frecuentes</h2>
        {faqs.map(({ q, a }) => (
          <details class="card-glass rounded-xl px-5 py-4 group">
            <summary class="cursor-pointer font-semibold text-[15px] list-none flex items-center justify-between gap-4">
              {q}<span class="shrink-0 transition-transform group-open:rotate-45" style="color:var(--brand)">+</span>
            </summary>
            <p class="mt-3 text-sm leading-relaxed" style="color:var(--text-muted)">{a}</p>
          </details>
        ))}
      </div>

      <div class="mt-14 flex flex-wrap gap-2.5">
        {[
          { label: 'Ver precios públicos', href: '/pricing' },
          { label: 'App para guardias', href: '/app-movil' },
          { label: 'Radio PTT', href: '/radio-ptt-para-guardias' },
          { label: 'Alternativa a TrackTik', href: '/alternativas-tracktik' },
          { label: '¿Cuánto cuesta un software de seguridad?', href: '/cuanto-cuesta-software-seguridad' },
        ].map((r) => (
          <a href={r.href} class="rounded-full border px-4 py-2 text-sm transition-colors hover:border-brand" style="color:var(--text-muted);border-color:var(--border)">{r.label}</a>
        ))}
      </div>

      <div class="on-dark mt-14 rounded-3xl px-8 py-12 text-center relative overflow-hidden" style="background:#141414">
        <div class="gold-line absolute top-0 left-0 right-0"></div>
        <h2 class="font-display font-bold text-2xl" style="color:#fff">Pruébalo con tu operación real</h2>
        <p class="mt-3 max-w-xl mx-auto" style="color:rgba(255,255,255,0.65)">Agenda una demo en español y compara con lo que usas hoy.</p>
        <div class="mt-6"><a href="/contact" class="btn-primary">Agendar una demo</a></div>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>
