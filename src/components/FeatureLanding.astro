---
/**
 * Reusable Spanish feature-landing-page template (SEO Phase 1). Each
 * /[feature] page passes pure content props; this renders the shared
 * structure: hero + product shot, pains, how-it-works, benefits, FAQ
 * (with FAQPage JSON-LD), related-feature links, and the closing CTA.
 * Pages using this are ES-only → they must pass hasAlternate={false}
 * to Layout themselves (this component is body-only).
 */
import PhoneFrame from './PhoneFrame.astro';

export interface FAQ { q: string; a: string }
export interface Props {
  badge: string;
  h1a: string;
  h1b: string;
  intro: string;
  /** Phone screenshot path (renders in PhoneFrame) … */
  phoneShot?: string;
  /** … or a CRM screenshot path (renders in a browser frame). */
  browserShot?: string;
  shotAlt: string;
  painsTitle: string;
  pains: { title: string; body: string }[];
  howTitle: string;
  how: { title: string; body: string }[];
  benefitsTitle: string;
  benefits: string[];
  faqs: FAQ[];
  related: { label: string; href: string }[];
  ctaTitle: string;
  ctaBody: string;
}

const {
  badge, h1a, h1b, intro, phoneShot, browserShot, shotAlt,
  painsTitle, pains, howTitle, how, benefitsTitle, benefits,
  faqs, related, ctaTitle, ctaBody,
} = Astro.props;
---

<Fragment set:html={`<script type="application/ld+json">${JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
})}</script>`} />

<main class="pt-28 lg:pt-32 overflow-x-clip">
  <!-- Hero -->
  <section class="pb-16 lg:pb-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
        <div>
          <span class="section-label mb-5 inline-flex">{badge}</span>
          <h1 class="font-display font-bold text-[2.4rem] lg:text-[3rem] leading-[1.07] tracking-tight">
            {h1a}<br /><span class="gold-gradient-text">{h1b}</span>
          </h1>
          <p class="mt-6 text-lg max-w-xl leading-relaxed" style="color:var(--text-muted)">{intro}</p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary">Solicitar demo</a>
            <a href="/pricing" class="btn-outline">Ver precios</a>
          </div>
          <p class="mt-6 text-xs font-mono uppercase tracking-[0.15em]" style="color:var(--text-faint)">
            Capturas reales del producto
          </p>
        </div>
        <div class="flex justify-center lg:justify-end">
          {phoneShot ? (
            <div class="w-[15.5rem] sm:w-[17rem]">
              <PhoneFrame src={phoneShot} alt={shotAlt} eager />
            </div>
          ) : (
            <div class="w-full max-w-xl rounded-2xl overflow-hidden" style="border:1px solid rgba(212,175,55,0.35);box-shadow:0 30px 60px -22px rgba(0,0,0,0.45)">
              <div class="flex items-center gap-2 px-3.5 py-2.5" style="background:#141414;border-bottom:1px solid rgba(255,255,255,0.06)">
                <div class="flex gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full" style="background:#ff5f56"></span>
                  <span class="w-2.5 h-2.5 rounded-full" style="background:#ffbd2e"></span>
                  <span class="w-2.5 h-2.5 rounded-full" style="background:#27c93f"></span>
                </div>
                <div class="flex-1 rounded-md px-3 py-1 text-[11px] font-mono mx-2 truncate" style="background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.4)">app.cguardpro.com</div>
              </div>
              <img src={browserShot} alt={shotAlt} class="w-full block" width="1600" height="1003" loading="eager" decoding="async" />
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <div class="gold-line"></div>

  <!-- Pains -->
  <section class="py-16 lg:py-20" style="background:var(--surface-2)">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-display font-bold text-[1.9rem] lg:text-[2.4rem] leading-[1.1] tracking-tight mb-10 max-w-2xl animate-on-scroll">{painsTitle}</h2>
      <div class="grid sm:grid-cols-3 gap-5">
        {pains.map((p) => (
          <div class="animate-on-scroll rounded-2xl p-6" style="background:var(--surface);border:1px solid var(--border);box-shadow:var(--card-shadow)">
            <h3 class="font-display font-semibold text-lg mb-2">{p.title}</h3>
            <p class="text-sm leading-relaxed" style="color:var(--text-muted)">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 lg:py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-display font-bold text-[1.9rem] lg:text-[2.4rem] leading-[1.1] tracking-tight mb-10 max-w-2xl animate-on-scroll">{howTitle}</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {how.map((s, i) => (
          <div class="animate-on-scroll rounded-2xl p-6" style={`background:var(--surface);border:1px solid var(--border);box-shadow:var(--card-shadow);transition-delay:${i * 60}ms`}>
            <span class="font-mono text-xs font-bold px-2.5 py-1 rounded-full border inline-block mb-4" style="color:var(--brand);border-color:var(--border-strong)">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="font-display font-semibold text-[17px] mb-2">{s.title}</h3>
            <p class="text-sm leading-relaxed" style="color:var(--text-muted)">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-16 lg:py-20" style="background:var(--surface-2)">
    <div class="max-w-6xl mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center">
      <h2 class="font-display font-bold text-[1.9rem] lg:text-[2.4rem] leading-[1.1] tracking-tight animate-on-scroll">{benefitsTitle}</h2>
      <ul class="rounded-2xl p-7 space-y-3.5 animate-on-scroll" style="background:var(--surface);border:1px solid var(--border);box-shadow:var(--card-shadow)">
        {benefits.map((b) => (
          <li class="flex items-start gap-3 text-[15px]" style="color:var(--text-muted)">
            <span class="mt-0.5 shrink-0 w-5 h-5 rounded-full flex items-center justify-center" style="background:rgba(200,134,10,0.12)">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#C8860A" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            {b}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 lg:py-20">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="font-display font-bold text-[1.9rem] lg:text-[2.4rem] tracking-tight mb-8 animate-on-scroll">Preguntas frecuentes</h2>
      <div class="space-y-3">
        {faqs.map(({ q, a }) => (
          <details class="card-glass rounded-xl px-5 py-4 group">
            <summary class="cursor-pointer font-semibold text-[15px] list-none flex items-center justify-between gap-4">
              {q}
              <span class="shrink-0 transition-transform group-open:rotate-45" style="color:var(--brand)">+</span>
            </summary>
            <p class="mt-3 text-sm leading-relaxed" style="color:var(--text-muted)">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related features -->
  <section class="pb-16">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-xs font-semibold tracking-[0.15em] uppercase mb-4" style="color:var(--brand)">También en CGuardPro</p>
      <div class="flex flex-wrap gap-2.5">
        {related.map((r) => (
          <a href={r.href} class="rounded-full border px-4 py-2 text-sm transition-colors hover:border-brand" style="color:var(--text-muted);border-color:var(--border)">{r.label}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="pb-24 px-6">
    <div class="max-w-4xl mx-auto rounded-3xl px-8 py-14 text-center relative overflow-hidden" style="background:#141414">
      <div class="gold-line absolute top-0 left-0 right-0"></div>
      <h2 class="font-display font-bold text-3xl text-white animate-on-scroll">{ctaTitle}</h2>
      <p class="mt-4 text-white/60 max-w-xl mx-auto animate-on-scroll">{ctaBody}</p>
      <div class="mt-8 animate-on-scroll">
        <a href="/contact" class="btn-primary">Agendar una demo</a>
      </div>
    </div>
  </section>
</main>
