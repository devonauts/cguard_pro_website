---
/**
 * Reusable LATAM country-page template (SEO Phase 2). Mirrors the /ecuador
 * hub structure: hero → country-localization cards → feature hub (links the
 * 8 Spanish feature LPs) → industries → FAQ (FAQPage JSON-LD) → CTA.
 * Country pages are ES-only → pass hasAlternate={false} to Layout.
 */
export interface FAQ { q: string; a: string }
export interface Props {
  flag: string;
  country: string;
  h1a: string;
  h1b: string;
  intro: string;
  localTitle: string;
  localCards: { t: string; d: string }[];
  faqs: FAQ[];
  ctaTitle: string;
  ctaBody: string;
}
const { flag, country, h1a, h1b, intro, localTitle, localCards, faqs, ctaTitle, ctaBody } = Astro.props;

const features = [
  { href: '/control-de-rondas-qr', title: 'Control de rondas con QR', desc: 'Puntos de control escaneados con el celular, verificados con GPS y hora de servidor.' },
  { href: '/control-de-asistencia-de-guardias', title: 'Control de asistencia', desc: 'Marcación con selfie y GPS en el puesto; consolidado listo para nómina.' },
  { href: '/roles-de-turnos-guardias', title: 'Roles de turnos', desc: 'Rotaciones 24x24 y 12x12 con coberturas de descanso automáticas.' },
  { href: '/libro-de-novedades-digital', title: 'Bitácora digital', desc: 'Novedades con foto y pase de turno automático al relevo.' },
  { href: '/boton-de-panico-guardias', title: 'Botón de pánico', desc: 'SOS del guardia y del cliente con alarma persistente en tu central.' },
  { href: '/supervision-gps-guardias', title: 'Supervisión GPS', desc: 'Mapa en vivo de guardias y patrullaje vehicular de supervisores.' },
  { href: '/radio-ptt-para-guardias', title: 'Radio PTT', desc: 'Canal abierto de voz en el celular — sin comprar radios.' },
  { href: '/portal-del-cliente', title: 'Portal del cliente', desc: 'Cada cliente ve rondas, novedades y avisos de turno de sus sitios.' },
];

const industries = [
  { href: '/seguridad-edificios-corporativos', name: 'Edificios corporativos' },
  { href: '/seguridad-centros-comerciales', name: 'Centros comerciales' },
  { href: '/seguridad-urbanizaciones-residenciales', name: 'Urbanizaciones' },
  { href: '/seguridad-hospitales-clinicas', name: 'Hospitales y clínicas' },
  { href: '/seguridad-sector-financiero', name: 'Sector financiero' },
  { href: '/seguridad-instituciones-educativas', name: 'Instituciones educativas' },
  { href: '/seguridad-parques-industriales', name: 'Parques industriales' },
];
---

<Fragment set:html={`<script type="application/ld+json">${JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ q, a }) => ({
    '@type': 'Question', name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
})}</script>`} />

<main class="pt-28 lg:pt-32">
  <section class="pb-14 lg:pb-20">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <span class="section-label mb-5 inline-flex">{flag} {country}</span>
      <h1 class="font-display font-bold text-[2.4rem] lg:text-[3.2rem] leading-[1.07] tracking-tight">
        {h1a}<br /><span class="gold-gradient-text">{h1b}</span>
      </h1>
      <p class="mt-6 text-lg leading-relaxed max-w-2xl mx-auto" style="color:var(--text-muted)">{intro}</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/contact" class="btn-primary">Solicitar demo</a>
        <a href="/pricing" class="btn-outline">Ver precios</a>
      </div>
    </div>
  </section>

  <div class="gold-line"></div>

  <section class="py-16 lg:py-20" style="background:var(--surface-2)">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-display font-bold text-[1.9rem] lg:text-[2.4rem] leading-[1.1] tracking-tight mb-10 max-w-3xl animate-on-scroll">{localTitle}</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {localCards.map((c) => (
          <div class="animate-on-scroll rounded-2xl p-6" style="background:var(--surface);border:1px solid var(--border);box-shadow:var(--card-shadow)">
            <h3 class="font-display font-semibold text-[17px] mb-2">{c.t}</h3>
            <p class="text-sm leading-relaxed" style="color:var(--text-muted)">{c.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-display font-bold text-[1.9rem] lg:text-[2.4rem] leading-[1.1] tracking-tight mb-4 animate-on-scroll">Todo lo que tu operación necesita</h2>
      <p class="mb-10 max-w-2xl text-lg" style="color:var(--text-muted)">Cada módulo funciona solo — y juntos son tu centro de mando completo.</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {features.map((f) => (
          <a href={f.href} class="animate-on-scroll rounded-2xl p-6 transition-transform duration-300 hover:-translate-y-1 block" style="background:var(--surface);border:1px solid var(--border);box-shadow:var(--card-shadow)">
            <h3 class="font-display font-semibold text-[16px] mb-2" style="color:var(--brand)">{f.title}</h3>
            <p class="text-sm leading-relaxed" style="color:var(--text-muted)">{f.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20" style="background:var(--surface-2)">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-display font-bold text-2xl mb-5 animate-on-scroll">Para cada tipo de instalación</h2>
      <div class="flex flex-wrap gap-2.5">
        {industries.map((i) => (
          <a href={i.href} class="rounded-full border px-4 py-2 text-sm transition-colors hover:border-brand" style="color:var(--text-muted);border-color:var(--border)">{i.name}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="font-display font-bold text-[1.9rem] lg:text-[2.4rem] tracking-tight mb-8 animate-on-scroll">Preguntas frecuentes</h2>
      <div class="space-y-3">
        {faqs.map(({ q, a }) => (
          <details class="card-glass rounded-xl px-5 py-4 group">
            <summary class="cursor-pointer font-semibold text-[15px] list-none flex items-center justify-between gap-4">
              {q}
              <span class="shrink-0 transition-transform group-open:rotate-45" style="color:var(--brand)">+</span>
            </summary>
            <p class="mt-3 text-sm leading-relaxed" style="color:var(--text-muted)">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="pb-24 px-6">
    <div class="max-w-4xl mx-auto rounded-3xl px-8 py-14 text-center relative overflow-hidden" style="background:#141414">
      <div class="gold-line absolute top-0 left-0 right-0"></div>
      <h2 class="font-display font-bold text-3xl text-white animate-on-scroll">{ctaTitle}</h2>
      <p class="mt-4 text-white/60 max-w-xl mx-auto animate-on-scroll">{ctaBody}</p>
      <div class="mt-8 animate-on-scroll">
        <a href="/contact" class="btn-primary">Agendar una demo</a>
      </div>
    </div>
  </section>
</main>
