---
/**
 * Template-download landing page (SEO Phase 3 — /recursos/*). Hero + free
 * download buttons (PDF + Excel, direct — no email gate), what's included,
 * how to use, FAQPage JSON-LD, and the digitize-with-CGuardPro pitch.
 * ES-only pages → pass hasAlternate={false} to Layout.
 */
export interface FAQ { q: string; a: string }
export interface Props {
  badge: string;
  h1a: string;
  h1b: string;
  intro: string;
  pdf: string;
  xlsx: string;
  includes: string[];
  howTo: { title: string; body: string }[];
  faqs: FAQ[];
  pitchTitle: string;
  pitchBody: string;
  pitchHref: string;
  pitchLabel: string;
  related: { label: string; href: string }[];
}
const { badge, h1a, h1b, intro, pdf, xlsx, includes, howTo, faqs, pitchTitle, pitchBody, pitchHref, pitchLabel, related } = Astro.props;
---

<Fragment set:html={`<script type="application/ld+json">${JSON.stringify({
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: faqs.map(({ q, a }) => ({ '@type': 'Question', name: q, acceptedAnswer: { '@type': 'Answer', text: a } })),
})}</script>`} />

<main class="pt-28 lg:pt-32 pb-24">
  <div class="max-w-3xl mx-auto px-6">
    <span class="section-label mb-5 inline-flex">{badge}</span>
    <h1 class="font-display font-bold text-[2.3rem] lg:text-[2.9rem] leading-[1.08] tracking-tight">
      {h1a}<br /><span class="gold-gradient-text">{h1b}</span>
    </h1>
    <p class="mt-6 text-lg leading-relaxed" style="color:var(--text-muted)">{intro}</p>

    <!-- Download card -->
    <div class="mt-10 rounded-2xl p-7" style="background:var(--surface);border:1px solid var(--border-strong);box-shadow:var(--card-shadow)">
      <p class="text-xs font-semibold tracking-[0.15em] uppercase mb-4" style="color:var(--brand)">Descarga gratuita — sin registro</p>
      <div class="flex flex-wrap gap-4">
        <a href={pdf} download class="btn-primary">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Descargar PDF (imprimir)
        </a>
        <a href={xlsx} download class="btn-outline">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Descargar Excel (editable)
        </a>
      </div>
    </div>

    <!-- What's included -->
    <h2 class="font-display font-bold text-2xl mt-14 mb-5">Qué incluye la plantilla</h2>
    <ul class="rounded-2xl p-7 space-y-3" style="background:var(--surface);border:1px solid var(--border);box-shadow:var(--card-shadow)">
      {includes.map((b) => (
        <li class="flex items-start gap-3 text-[15px]" style="color:var(--text-muted)">
          <span class="mt-0.5 shrink-0 w-5 h-5 rounded-full flex items-center justify-center" style="background:rgba(200,134,10,0.12)">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#C8860A" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          </span>
          {b}
        </li>
      ))}
    </ul>

    <!-- How to use -->
    <h2 class="font-display font-bold text-2xl mt-14 mb-5">Cómo usarla bien</h2>
    <div class="space-y-4">
      {howTo.map((s, i) => (
        <div class="rounded-2xl p-6 flex gap-4" style="background:var(--surface);border:1px solid var(--border)">
          <span class="font-mono text-xs font-bold px-2.5 py-1 rounded-full border self-start shrink-0" style="color:var(--brand);border-color:var(--border-strong)">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <h3 class="font-display font-semibold text-[16px] mb-1">{s.title}</h3>
            <p class="text-sm leading-relaxed" style="color:var(--text-muted)">{s.body}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- FAQ -->
    <h2 class="font-display font-bold text-2xl mt-14 mb-5">Preguntas frecuentes</h2>
    <div class="space-y-3">
      {faqs.map(({ q, a }) => (
        <details class="card-glass rounded-xl px-5 py-4 group">
          <summary class="cursor-pointer font-semibold text-[15px] list-none flex items-center justify-between gap-4">
            {q}<span class="shrink-0 transition-transform group-open:rotate-45" style="color:var(--brand)">+</span>
          </summary>
          <p class="mt-3 text-sm leading-relaxed" style="color:var(--text-muted)">{a}</p>
        </details>
      ))}
    </div>

    <!-- Digitize pitch -->
    <div class="on-dark mt-14 rounded-3xl px-8 py-12 relative overflow-hidden" style="background:#141414">
      <div class="gold-line absolute top-0 left-0 right-0"></div>
      <h2 class="font-display font-bold text-2xl" style="color:#fff">{pitchTitle}</h2>
      <p class="mt-3 max-w-2xl" style="color:rgba(255,255,255,0.65)">{pitchBody}</p>
      <div class="mt-6 flex flex-wrap gap-4">
        <a href={pitchHref} class="btn-primary">{pitchLabel}</a>
        <a href="/contact" class="btn-outline" style="color:#fff">Agendar una demo</a>
      </div>
    </div>

    <div class="mt-12 flex flex-wrap gap-2.5">
      {related.map((r) => (
        <a href={r.href} class="rounded-full border px-4 py-2 text-sm transition-colors hover:border-brand" style="color:var(--text-muted);border-color:var(--border)">{r.label}</a>
      ))}
    </div>
  </div>
</main>
