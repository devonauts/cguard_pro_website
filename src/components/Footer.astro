---
import { useTranslations, localePath } from '../i18n/index';
import type { Lang } from '../i18n/index';

interface Props { lang?: Lang }
const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);
const p = (path: string) => localePath(lang, path);

const year = new Date().getFullYear();

const links = {
  [t.footer.sections.product]: [
    { href: p('/#features'), label: t.footer.links.features },
    { href: p('/pricing'), label: t.footer.links.pricing },
    { href: p('/#how-it-works'), label: t.footer.links.howItWorks },
    { href: p('/contact'), label: t.footer.links.requestDemo },
  ],
  [t.footer.sections.company]: [
    { href: p('/about'), label: t.footer.links.about },
    { href: p('/contact'), label: t.footer.links.contact },
    { href: p('/privacy'), label: t.footer.links.privacy },
    { href: p('/terms'), label: t.footer.links.terms },
  ],
  [t.footer.sections.industry]: [
    { href: p('/security-guard-management'), label: t.footer.links.guardManagement },
    { href: p('/client-management'), label: t.footer.links.clientManagement },
    { href: p('/incident-reporting'), label: t.footer.links.incidentReporting },
    { href: p('/mobile-app'), label: t.footer.links.mobileApp },
  ],
};
---

<footer class="border-t border-white/5 bg-navy-900">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 mb-12">

      <!-- Brand Column -->
      <div class="lg:col-span-2">
        <a href={p('/')} class="flex items-center mb-4 w-fit">
          <img
            src="/logo.png"
            alt="C-Guard Pro"
            class="h-10 w-auto"
          />
        </a>
        <p class="text-white/50 text-sm leading-relaxed max-w-xs mb-6">
          {t.footer.tagline}
        </p>
        <a href="https://app.cguardpro.com" class="btn-primary text-sm py-2">
          {t.footer.getStarted}
        </a>
      </div>

      <!-- Link Columns -->
      {Object.entries(links).map(([section, items]) => (
        <div>
          <h3 class="text-xs font-mono font-medium text-white/30 tracking-widest uppercase mb-4">{section}</h3>
          <ul class="flex flex-col gap-2.5">
            {items.map(({ href, label }) => (
              <li>
                <a href={href} class="text-sm text-white/60 hover:text-white transition-colors duration-200">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-white/30 text-xs">
        &copy; {year} CGuardPro. {t.footer.rights}
      </p>
      <p class="text-white/20 text-xs font-mono">
        {t.footer.builtFor}
      </p>
    </div>
  </div>
</footer>
