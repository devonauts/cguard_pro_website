---
import { useTranslations, localePath } from '../i18n/index';
import type { Lang } from '../i18n/index';

interface Props { lang?: Lang }
const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);
const p = (path: string) => localePath(lang, path);

const year = new Date().getFullYear();

const links = {
  // ES gets a dedicated feature-pages column (the SEO landing pages);
  // EN has no feature pages yet, so its footer keeps 3 columns.
  ...(lang === 'es'
    ? {
        'Funcionalidades': [
          { href: '/control-de-rondas-qr', label: 'Control de Rondas QR' },
          { href: '/control-de-asistencia-de-guardias', label: 'Control de Asistencia' },
          { href: '/roles-de-turnos-guardias', label: 'Roles de Turnos' },
          { href: '/libro-de-novedades-digital', label: 'Libro de Novedades Digital' },
          { href: '/boton-de-panico-guardias', label: 'Botón de Pánico' },
          { href: '/supervision-gps-guardias', label: 'Supervisión GPS' },
          { href: '/radio-ptt-para-guardias', label: 'Radio PTT' },
          { href: '/portal-del-cliente', label: 'Portal del Cliente' },
        ],
      }
    : {}),
  [t.footer.sections.product]: [
    { href: p('/#features'), label: t.footer.links.features },
    { href: p('/app-movil'), label: t.footer.links.mobileApp },
    { href: p('/pricing'), label: t.footer.links.pricing },
    { href: p('/#how-it-works'), label: t.footer.links.howItWorks },
    { href: p('/contact'), label: t.footer.links.requestDemo },
  ],
  [t.footer.sections.company]: [
    { href: p('/about'), label: t.footer.links.about },
    { href: lang === 'es' ? '/blog' : '/en/blog', label: 'Blog' },
    ...(lang === 'es'
      ? [
          { href: '/cuanto-cuesta-software-seguridad', label: 'Guía de Precios 2026' },
          { href: '/alternativas-tracktik', label: 'Alternativa a TrackTik' },
        ]
      : []),
    { href: p('/contact'), label: t.footer.links.contact },
    { href: p('/privacy'), label: t.footer.links.privacy },
    { href: p('/terms'), label: t.footer.links.terms },
  ],
  [t.footer.sections.industry]: lang === 'es' ? [
    { href: '/ecuador', label: 'Software en Ecuador' },
    { href: '/colombia', label: 'Software en Colombia' },
    { href: '/mexico', label: 'Software en México' },
    { href: '/peru', label: 'Software en Perú' },
    { href: '/chile', label: 'Software en Chile' },
    { href: '/quito', label: 'Seguridad en Quito' },
    { href: '/guayaquil', label: 'Seguridad en Guayaquil' },
    { href: '/cuenca', label: 'Seguridad en Cuenca' },
    { href: '/seguridad-edificios-corporativos', label: 'Edificios Corporativos' },
    { href: '/seguridad-centros-comerciales', label: 'Centros Comerciales' },
    { href: '/seguridad-urbanizaciones-residenciales', label: 'Urbanizaciones' },
    { href: '/seguridad-hospitales-clinicas', label: 'Hospitales y Clínicas' },
    { href: '/seguridad-sector-financiero', label: 'Sector Financiero' },
    { href: '/seguridad-instituciones-educativas', label: 'Instituciones Educativas' },
    { href: '/seguridad-parques-industriales', label: 'Parques Industriales' },
    { href: '/seguridad-embajadas-organismos', label: 'Embajadas y Organismos' },
  ] : [
    { href: '/en/austin', label: 'Security in Austin' },
    { href: '/en/san-antonio', label: 'Security in San Antonio' },
    { href: '/en/houston', label: 'Security in Houston' },
    { href: '/en/dallas', label: 'Security in Dallas' },
    { href: '/en/round-rock', label: 'Security in Round Rock' },
  ],
};
---

<footer class="border-t border-white/5 bg-navy-900">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class={`grid grid-cols-1 md:grid-cols-2 gap-12 mb-12 ${lang === 'es' ? 'lg:grid-cols-6' : 'lg:grid-cols-5'}`}>

      <!-- Brand Column -->
      <div class="lg:col-span-2">
        <a href={p('/')} class="flex items-center mb-4 w-fit">
          <img
            src="/logo.png"
            alt="C-Guard Pro"
            class="h-10 w-auto"
          />
        </a>
        <p class="text-white/50 text-sm leading-relaxed max-w-xs mb-6">
          {t.footer.tagline}
        </p>
        <a href="https://app.cguardpro.com" class="btn-primary text-sm py-2">
          {t.footer.getStarted}
        </a>
      </div>

      <!-- Link Columns -->
      {Object.entries(links).map(([section, items]) => (
        <div>
          <h3 class="text-xs font-mono font-medium text-white/30 tracking-widest uppercase mb-4">{section}</h3>
          <ul class="flex flex-col gap-2.5">
            {items.map(({ href, label }) => (
              <li>
                <a href={href} class="text-sm text-white/60 hover:text-white transition-colors duration-200">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-white/30 text-xs">
        &copy; {year} CGuardPro. {t.footer.rights}
      </p>
      <p class="text-white/20 text-xs font-mono">
        {t.footer.builtFor}
      </p>
    </div>
  </div>
</footer>
