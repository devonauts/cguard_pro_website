---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { useTranslations, localePath } from '../i18n/index';
import type { Lang } from '../i18n/index';

interface Props { lang?: Lang; overVideo?: boolean }
const { lang = 'es', overVideo = false } = Astro.props;
const t = useTranslations(lang);
const p = (path: string) => localePath(lang, path);

const navLinks = [
  { href: p('/#features'), label: t.nav.features },
  { href: p('/#how-it-works'), label: t.nav.howItWorks },
  { href: p('/pricing'), label: t.nav.pricing },
  { href: p('/about'), label: t.nav.about },
  { href: lang === 'es' ? '/blog' : '/en/blog', label: t.nav.blog },
];

const pathname = Astro.url.pathname;
---

<header id="navbar" data-over-video={overVideo ? 'true' : undefined} class:list={["fixed top-0 left-0 right-0 z-50 transition-all duration-300", overVideo && 'on-video']}>
  <nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href={p('/')} class="flex items-center group" aria-label="CGuardPro Home">
      <img
        src="/logo.png"
        alt="C-Guard Pro — Seguridad Inteligente"
        class="site-logo h-10 w-auto group-hover:opacity-90 transition-opacity duration-300"
      />
    </a>

    <!-- Desktop Links -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="text-sm font-medium text-white/70 hover:text-white transition-colors duration-200
                   relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[1px]
                   after:bg-brand after:transition-all after:duration-300 hover:after:w-full"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA + Language Switcher -->
    <div class="hidden md:flex items-center gap-3">
      <button data-theme-toggle class="p-2 rounded-lg text-white/70 hover:text-white hover:bg-white/5 transition-colors" aria-label="Cambiar tema claro/oscuro">
        <svg class="theme-icon-dark" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="theme-icon-light" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
      </button>
      <LanguageSwitcher lang={lang} pathname={pathname} />
      <a href="https://app.cguardpro.com" class="text-sm font-medium text-white/70 hover:text-white transition-colors">
        {t.nav.signIn}
      </a>
      <a href={p('/contact')} class="btn-primary text-sm py-2 px-5">
        {t.nav.requestDemo}
      </a>
    </div>

    <!-- Mobile Menu Toggle -->
    <button id="menu-toggle" class="md:hidden p-2 rounded-lg hover:bg-white/5 transition-colors"
            aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu">
      <svg id="icon-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <svg id="icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/5 bg-navy/95 backdrop-blur-lg">
    <ul class="px-6 py-4 flex flex-col gap-4">
      {navLinks.map(({ href, label }) => (
        <li>
          <a href={href} class="text-white/80 hover:text-white font-medium transition-colors block py-1">{label}</a>
        </li>
      ))}
      <li class="pt-2 border-t border-white/5 flex flex-col gap-3">
        <div class="flex items-center justify-between">
          <a href="https://app.cguardpro.com" class="text-white/70 hover:text-white text-sm font-medium transition-colors">{t.nav.signIn}</a>
          <div class="flex items-center gap-2">
            <button data-theme-toggle class="p-2 rounded-lg text-white/70 hover:text-white hover:bg-white/5 transition-colors" aria-label="Cambiar tema claro/oscuro">
              <svg class="theme-icon-dark" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
              <svg class="theme-icon-light" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
            </button>
            <LanguageSwitcher lang={lang} pathname={pathname} />
          </div>
        </div>
        <a href={p('/contact')} class="btn-primary text-sm justify-center">{t.nav.requestDemo}</a>
      </li>
    </ul>
  </div>
</header>

<script>
  const navbar  = document.getElementById('navbar')!;
  const toggle  = document.getElementById('menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const iconOpen  = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  // Scroll-based navbar background. On pages with a video hero the navbar
  // starts transparent over dark footage (keep light text via .on-video),
  // then switches to the themed solid bar once scrolled.
  const overVideo = navbar.dataset.overVideo === 'true';
  const onScroll = () => {
    if (window.scrollY > 20) {
      navbar.classList.add('bg-navy/90', 'backdrop-blur-lg', 'border-b', 'border-white/5', 'shadow-xl');
      if (overVideo) navbar.classList.remove('on-video');
    } else {
      navbar.classList.remove('bg-navy/90', 'backdrop-blur-lg', 'border-b', 'border-white/5', 'shadow-xl');
      if (overVideo) navbar.classList.add('on-video');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile menu toggle
  toggle.addEventListener('click', () => {
    const isOpen = !mobileMenu.classList.contains('hidden');
    mobileMenu.classList.toggle('hidden', isOpen);
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close menu on link click
  mobileMenu.querySelectorAll('a').forEach(a =>
    a.addEventListener('click', () => { mobileMenu.classList.add('hidden'); })
  );

  // Light / dark theme toggle (persists the choice; theme-init in the layout applies it)
  document.querySelectorAll('[data-theme-toggle]').forEach((btn) =>
    btn.addEventListener('click', () => {
      const isLight = document.documentElement.classList.toggle('light');
      try { localStorage.setItem('theme', isLight ? 'light' : 'dark'); } catch (e) {}
    })
  );
</script>
